# dotctl tty-clock theme: gruvbox
# Sourced by the tty-clock-themed wrapper. TTYCLOCK_ARGS is expanded before
# any user args, so `tty-clock-themed -t` still works to toggle 12h mode.
#
# tty-clock(1) color palette (-C N): 0=black 1=red 2=green 3=yellow
# 4=blue 5=magenta 6=cyan 7=white. Gruvbox → yellow (signature warm).
TTYCLOCK_ARGS=(-c -C 3)
