#!/bin/sh

# Toggle: if any wofi is open, close it
if pgrep -x wofi >/dev/null; then
  pkill -x wofi
  exit 0
fi

choice="$(
  printf '%s\n' \
    '🎧 Headset' \
    '🖥️ Speakers (HDMI)' \
    '🎚️ AUX / Analog' \
    '🔵 Bluetooth' |
  wofi --dmenu \
       --prompt 'Audio output' \
       --location 3 \
       --insensitive \
       --width 420 \
       --height 280 \
       --xoffset -35 \
       --yoffset 15
)"

case "$choice" in
  "🎧 Headset")        audio-output headset ;;
  "🖥️ Speakers (HDMI)") audio-output speaker ;;
  "🎚️ AUX / Analog")  audio-output aux ;;
  "🔵 Bluetooth")      audio-output bluetooth ;;
  *) exit 0 ;;
esac

