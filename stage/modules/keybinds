#!/bin/bash
# keybinds - hyprland keybinds cheatsheet (wofi)
#
# Reads ~/.config/hypr/hyprland.conf, follows `source = ...` recursively,
# and emits a wofi menu of bind lines that have a trailing `# Label`
# annotation. hyprland.conf itself is never modified - users opt in by
# adding labels to whichever binds they want surfaced.
#
# See `keybinds --help` for the annotation grammar.

set -euo pipefail
shopt -s extglob

# Toggle off if wofi is already up
if pgrep -x wofi >/dev/null; then
  pkill -x wofi
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────────
#  Config
# ──────────────────────────────────────────────────────────────────────────────

readonly HYPR_CONF="${HYPR_CONF:-$HOME/.config/hypr/hyprland.conf}"
readonly DEFAULT_HEADER_COLOR='#83a598'
HEADER_COLOR="${KEYBINDS_HEADER_COLOR:-$DEFAULT_HEADER_COLOR}"
PRINT_ONLY=false

die()  { printf 'keybinds: %s\n' "$*" >&2; exit 1; }
warn() { printf 'keybinds: %s\n' "$*" >&2; }

case "${1:-}" in
  -h|--help|help)
    cat <<'EOF'
keybinds - hyprland keybinds cheatsheet (wofi)

USAGE
  keybinds            Toggle the cheatsheet (open if closed, close if open)
  keybinds --print    Dump the cheatsheet to stdout instead of wofi
  keybinds -h         This help

ANNOTATION GRAMMAR
  Add a trailing `# Label` to any bind line you want to appear:

    # Browser binds                            ← section header
    bind = $mainMod, B, exec, $browser  # Brave             ← row label
    bind = $mainMod SHIFT, B, exec, $bp # Brave (Incognito)

  Bindings without a trailing `# Label` are silently skipped, so the
  cheatsheet only ever shows what you explicitly opted in.

  Section headers come from the FIRST stand-alone `# ...` comment line
  of each comment block preceding a group of binds. Multi-line block
  comments use only the first line, so noisy explainer paragraphs do
  not pollute the section name. Blank lines reset the block.

  All `bind*` variants are recognised: bind, bindd, bindel, bindl,
  bindm, binde. Commented-out binds (`#bind = ...`) with a trailing
  label are still surfaced - useful for "disabled but documented".

  Sourced .conf files are followed automatically via `source = ...`,
  so dotctl-keybinds.conf and any other helpers you source are
  included with no extra wiring.

ENV
  HYPR_CONF              Path to hyprland.conf
                         (default: ~/.config/hypr/hyprland.conf)
  KEYBINDS_HEADER_COLOR  Pango color for section headers
                         (default: #83a598)
EOF
    exit 0;;
  --print) PRINT_ONLY=true;;
  '') ;;
  *) die "unknown argument: $1 (try \`keybinds --help\`)";;
esac

command -v wofi >/dev/null 2>&1 || [[ "$PRINT_ONLY" == "true" ]] || die "wofi not found in PATH"

# ──────────────────────────────────────────────────────────────────────────────
#  Parser state
# ──────────────────────────────────────────────────────────────────────────────

declare -a SECTIONS=()
declare -A SECTION_ROWS=()
declare -A SEEN_FILES=()
SECTION_CANDIDATE=""
PREV_WAS_COMMENT=false
MAIN_MOD="SUPER"

# ──────────────────────────────────────────────────────────────────────────────
#  Helpers (REPLY-style: set REPLY/COMBO instead of stdout, so the hot parse
#  loop never forks a subshell. Cuts wall time on a 600-line conf from ~1.1s
#  to <100ms by avoiding ~500 fork/exec round-trips.)
# ──────────────────────────────────────────────────────────────────────────────

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  REPLY="$s"
}

resolve_path() {
  local p="$1"
  p="${p/#\~/$HOME}"
  p="${p//\$HOME/$HOME}"
  REPLY="$p"
}

# Strip leading/trailing #, -, space from a comment line so headers like
# "### MONITORS ###" or "# --- Audio output switching ---" become "MONITORS"
# and "Audio output switching" respectively.
clean_section() {
  local s="$1"
  s="${s##+([[:space:]#\-])}"
  s="${s%%+([[:space:]#\-])}"
  REPLY="$s"
}

fmt_mod() {
  case "$1" in
    '$mainMod')                                REPLY="$MAIN_MOD" ;;
    Control_L|Control_R|CONTROL|Control|Ctrl)  REPLY='CTRL' ;;
    CTRL_ALT)                                  REPLY='CTRL + ALT' ;;
    ALT_SHIFT)                                 REPLY='ALT + SHIFT' ;;
    SHIFT_ALT)                                 REPLY='SHIFT + ALT' ;;
    *_*)                                       REPLY="${1//_/ + }" ;;
    *)                                         REPLY="$1" ;;
  esac
}

fmt_key() {
  case "$1" in
    left|Left)             REPLY='←' ;;
    right|Right)           REPLY='→' ;;
    up|Up)                 REPLY='↑' ;;
    down|Down)             REPLY='↓' ;;
    mouse_down)            REPLY='wheel ↓' ;;
    mouse_up)              REPLY='wheel ↑' ;;
    mouse:272)             REPLY='LMB' ;;
    mouse:273)             REPLY='RMB' ;;
    XF86AudioRaiseVolume)  REPLY='Volume +' ;;
    XF86AudioLowerVolume)  REPLY='Volume −' ;;
    XF86AudioMute)         REPLY='Mute' ;;
    XF86AudioMicMute)      REPLY='Mic Mute' ;;
    XF86AudioPlay)         REPLY='Play' ;;
    XF86AudioPause)        REPLY='Pause' ;;
    XF86AudioNext)         REPLY='Next' ;;
    XF86AudioPrev)         REPLY='Prev' ;;
    XF86MonBrightnessUp)   REPLY='Brightness +' ;;
    XF86MonBrightnessDown) REPLY='Brightness −' ;;
    *)                     REPLY="$1" ;;
  esac
}

# Sets COMBO. Avoids the per-token subshell that `out+="$(fmt_mod ...) +"`
# would incur (each call to fmt_mod is otherwise a fork).
format_combo() {
  local mods_raw="$1" key="$2" tok
  COMBO=""
  for tok in $mods_raw; do
    [[ -n "$tok" ]] || continue
    fmt_mod "$tok"
    COMBO+="$REPLY + "
  done
  fmt_key "$key"
  COMBO+="$REPLY"
}

# ──────────────────────────────────────────────────────────────────────────────
#  Recursive parser
# ──────────────────────────────────────────────────────────────────────────────

parse_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  [[ -n "${SEEN_FILES[$file]:-}" ]] && return 0
  SEEN_FILES[$file]=1

  local line trimmed body label rest mods_raw key sect target hdr
  while IFS= read -r line || [[ -n "$line" ]]; do
    trim "$line"; trimmed="$REPLY"

    # Blank line: reset comment-block tracking, but keep section_candidate
    # so the next bind still inherits the previous header.
    if [[ -z "$trimmed" ]]; then
      PREV_WAS_COMMENT=false
      continue
    fi

    # source = directive (recursive include)
    if [[ "$trimmed" =~ ^source[[:space:]]*=[[:space:]]*(.+)$ ]]; then
      target="${BASH_REMATCH[1]}"
      target="${target%%#*}"
      trim "$target";        target="$REPLY"
      resolve_path "$target"; target="$REPLY"
      PREV_WAS_COMMENT=false
      parse_file "$target"
      continue
    fi

    # $mainMod assignment - capture so $mainMod renders as the user's choice
    if [[ "$trimmed" =~ ^\$mainMod[[:space:]]*=[[:space:]]*([A-Za-z][A-Za-z0-9_]*) ]]; then
      MAIN_MOD="${BASH_REMATCH[1]}"
      PREV_WAS_COMMENT=false
      continue
    fi

    # bind line (active OR commented-out). Match before the comment branch
    # so `#bind = ...` is treated as a bind, not a section header.
    if [[ "$trimmed" =~ ^#?bind[a-z]?[[:space:]]*= ]]; then
      # Extract trailing label: greedy match up to the LAST `#` that is
      # preceded by something non-`#`. Bind lines never legitimately
      # contain `#` in their dispatcher args, so this is safe.
      if [[ "$trimmed" =~ ^(#?bind[a-z]?[[:space:]]*=[^#]*)\#[[:space:]]*(.+)$ ]]; then
        body="${BASH_REMATCH[1]}"
        trim "${BASH_REMATCH[2]}"; label="$REPLY"
      else
        PREV_WAS_COMMENT=false
        continue  # no label → opt-out
      fi

      # Strip optional comment-out marker, then `bind* = `
      trim "${body#\#}"; body="$REPLY"
      trim "${body#*=}"; rest="$REPLY"

      # Split first two comma fields: MODS, KEY
      trim "${rest%%,*}"; mods_raw="$REPLY"
      rest="${rest#*,}"
      trim "${rest%%,*}"; key="$REPLY"

      sect="${SECTION_CANDIDATE:-Other}"
      sect="${sect% binds}"
      sect="${sect% bind}"

      if [[ -z "${SECTION_ROWS[$sect]:-}" ]]; then
        SECTIONS+=("$sect")
        SECTION_ROWS[$sect]=""
      fi
      format_combo "$mods_raw" "$key"
      SECTION_ROWS[$sect]+="$label"$'\t'"$COMBO"$'\n'
      PREV_WAS_COMMENT=false
      continue
    fi

    # Section header: stand-alone comment line. Only the FIRST comment of
    # each block becomes the candidate; subsequent comment lines (descriptive
    # body text) are ignored so they do not override the title.
    if [[ "$trimmed" =~ ^# ]]; then
      if ! $PREV_WAS_COMMENT; then
        clean_section "$trimmed"; hdr="$REPLY"
        if [[ "$hdr" =~ [A-Za-z] ]]; then
          SECTION_CANDIDATE="$hdr"
        fi
      fi
      PREV_WAS_COMMENT=true
      continue
    fi

    # Anything else (config blocks, windowrules, workspace=, etc.)
    PREV_WAS_COMMENT=false
  done < "$file"
}

# ──────────────────────────────────────────────────────────────────────────────
#  Render
# ──────────────────────────────────────────────────────────────────────────────

render() {
  local sect rows label combo width=0 row_width=0 line_width

  for sect in "${SECTIONS[@]}"; do
    while IFS=$'\t' read -r label combo; do
      [[ -z "$label" ]] && continue
      (( ${#label} > width )) && width=${#label}
      line_width=$(( ${#label} + ${#combo} ))
      (( line_width > row_width )) && row_width=$line_width
    done <<< "${SECTION_ROWS[$sect]}"
  done
  (( width > 32 )) && width=32

  # Header rule total width: match the widest row (label + " → " + combo) so
  # the divider sits flush with the row content and never overflows.
  local target=$(( row_width + 5 ))

  local first=true dashes_l dashes_r pad l r
  for sect in "${SECTIONS[@]}"; do
    rows="${SECTION_ROWS[$sect]}"
    [[ -z "$rows" ]] && continue
    $first || printf '\n'
    first=false
    pad=$(( target - ${#sect} - 2 ))
    (( pad < 4 )) && pad=4
    l=$(( pad / 2 )); r=$(( pad - l ))
    printf -v dashes_l '%*s' "$l" ''
    printf -v dashes_r '%*s' "$r" ''
    dashes_l="${dashes_l// /─}"
    dashes_r="${dashes_r// /─}"
    printf '<span foreground="%s"><b>%s %s %s</b></span>\n' \
      "$HEADER_COLOR" "$dashes_l" "$sect" "$dashes_r"
    while IFS=$'\t' read -r label combo; do
      [[ -z "$label" ]] && continue
      printf '󰆍 %-*s → %s\n' "$width" "$label" "$combo"
    done <<< "$rows"
  done
}

# ──────────────────────────────────────────────────────────────────────────────
#  Main
# ──────────────────────────────────────────────────────────────────────────────

[[ -f "$HYPR_CONF" ]] || die "hyprland.conf not found at $HYPR_CONF"

parse_file "$HYPR_CONF"

if (( ${#SECTIONS[@]} == 0 )); then
  die "no annotated binds found in $HYPR_CONF (or any sourced files). See \`keybinds --help\` for the annotation grammar."
fi

if [[ "$PRINT_ONLY" == "true" ]]; then
  render
  exit 0
fi

render | wofi \
  --dmenu \
  --allow-markup \
  --prompt 'Keybindings' \
  --location 7 \
  --width 750 \
  --height 1100 \
  --xoffset 10 \
  --yoffset -35 \
  --insensitive
