#!/bin/sh

# Toggle: if any wofi is open, close it
if pgrep -x wofi >/dev/null; then
  pkill -x wofi
  exit 0
fi

# Open a small power menu in the top-left
choice="$(
  printf '%s\n' " Poweroff" " Reboot" "󰒲 Logout" |
  wofi --dmenu \
       --prompt 'Power Menu' \
       --location 1 \
       --insensitive \
       --width 300 \
       --height 235 \
       --xoffset 10 \
       --yoffset 10
)"

# Detect init system: systemd, elogind (OpenRC/runit), raw OpenRC, or sysv.
if [ -d /run/systemd/system ]; then
  poweroff_cmd="systemctl poweroff"
  reboot_cmd="systemctl reboot"
elif command -v loginctl >/dev/null 2>&1; then
  # elogind on OpenRC/runit: polkit-authorized, no root required.
  poweroff_cmd="loginctl poweroff"
  reboot_cmd="loginctl reboot"
elif command -v openrc-shutdown >/dev/null 2>&1; then
  poweroff_cmd="openrc-shutdown -p now"
  reboot_cmd="openrc-shutdown -r now"
else
  poweroff_cmd="poweroff"
  reboot_cmd="reboot"
fi

case "$choice" in
  " Poweroff") $poweroff_cmd ;;
  " Reboot")   $reboot_cmd ;;
  "󰒲 Logout")  hyprctl dispatch exit ;;
esac
