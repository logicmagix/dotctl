# dotctl - hyprland border/glow colors
# Generated from the active waybar palette - do not hand-edit.
# Regenerated on every `dotctl apply` and sourced from hyprland.conf.
#
# To activate, add this line to ~/.config/hypr/hyprland.conf:
#     source = ~/.config/hypr/dotctl-colors.conf

general {
    col.active_border   = rgba(__CYAN__ee) rgba(__YELLOW__ee) 45deg
    col.inactive_border = rgba(__BG3__aa)
}

decoration {
    shadow {
        color           = rgba(__SHADOW_COLOR____SHADOW_ALPHA__)
    }
}
