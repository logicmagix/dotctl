  dotctl sync wallpaper waybar     Wallpaper follows waybar color
  dotctl sync all kitty            All elements take kitty's color+font
  dotctl preset save laptop        Snapshot current state
  dotctl preset load tv            Restore snapshot
  dotctl scan                      Auto-generate cycle scripts for new wallpaper dirs
  dotctl scan --dry-run            Preview what scan would create
  dotctl new wallpaper forest      Scaffold one new wallpaper theme by hand

STATE
  ~/.config/dotctl/config       23-field KEY=value, hand-editable, flock-guarded
  ~/.config/dotctl/presets/     Saved presets (one .conf per preset)
  ~/.config/dotctl/cycle/       cycle-hyprpaper-<theme> scripts + _cycle-hyprpaper.template
  ~/.cache/dotctl/lock          Runtime lockfile
  /tmp/dotctl.log               Event log (apply, cycle, sync, watch)

SOURCES (read-only from dotctl's perspective)
  ~/.config/cava/<color>/config
  ~/.config/kitty/<color>_<font>/kitty.conf
  ~/.config/mako/<color>_<font>/config
  ~/.config/wofi/<color>_<font>/<variant>/style.css
  ~/.config/waybar/<style>_<scope>/{config.jsonc,style.css}   (canonical, palette-injected)
  ~/.config/waybar/palettes/<color>.palette
  ~/.config/waybar/fonts/<font>.fontdef
  ~/.config/waybar/decorators/<decor>.glyphs
  ~/.config/tty-clock/<color>/config                          (optional - only when tty-clock was installed)
  ~/.local/share/dotctl/dotctl-colors.conf.tmpl               (hyprland color template)
  ~/Pictures/dotctl/wallpapers/<theme>/   + ~/.config/dotctl/cycle/cycle-hyprpaper-<theme>

HYPRLAND INTEGRATION
  Install drops two sourceable snippets into ~/.config/hypr/. Add both to
  the BOTTOM of your hyprland.conf (later sources override earlier ones):

    source = ~/.config/hypr/dotctl-keybinds.conf   # cycle + audio binds
    source = ~/.config/hypr/dotctl-colors.conf     # palette-driven colors + shadow/glow

  Then: hyprctl reload

  The keybinds snippet ships with:
    bind = SUPER ALT, Right, exec, dotctl cycle wallpaper next
    bind = SUPER ALT, Left,  exec, dotctl cycle wallpaper prev
    bind = SUPER ALT, Up,    exec, dotctl cycle waybar    next
    bind = SUPER ALT, Down,  exec, dotctl cycle waybar    prev

  dotctl never edits hyprland.conf itself.
EOF
}

# ──────────────────────────────────────────────────────────────────────────────
#  Dispatcher
# ──────────────────────────────────────────────────────────────────────────────

main() {
  local action="${1:-help}"
  [[ $# -gt 0 ]] && shift
  case "$action" in
    configure)        cmd_configure "$@";;
    show)             cmd_show "$@";;
    set)              cmd_set "$@";;
    cycle)            cmd_cycle "$@";;
    sync)             cmd_sync "$@";;
    list)             cmd_list "$@";;
    preset)           cmd_preset "$@";;
    new)              cmd_new "$@";;
    scan)             cmd_scan "$@";;
    apply)            cmd_apply "$@";;
    watch)            cmd_watch "$@";;
    help|-h|--help|'') cmd_help;;
    *) die "unknown action \`$action\` - try \`dotctl help\`";;
  esac
}

main "$@"
