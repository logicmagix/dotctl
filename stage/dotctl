# ──────────────────────────────────────────────────────────────────────────────
#  `cycle` - the 4 keybind entry points
# ──────────────────────────────────────────────────────────────────────────────

cmd_cycle() {
  local target="${1:-}" direction="${2:-}"

  case "$target" in
    -h|--help|help|'')
      cat <<'EOF'
dotctl cycle <wallpaper|waybar> <next|prev>

  wallpaper next|prev   Step to the next/previous image within the active
                        wallpaper theme. Delegates to cycle-hyprpaper-<theme>.
  waybar    next|prev   Rotate WAYBAR_STYLE × WAYBAR_SCOPE through:
                          pill_full → pill_minimal → console_full → console_minimal
                        and wrap. Color, font, decor, vpn, transparent, opacity,
                        and launcher-logo are preserved across the rotation.

These are the keybind entry points; see `dotctl help` for the
hyprland.conf snippet.
EOF
      return 0;;
  esac

  [[ -n "$target" && -n "$direction" ]] || die "usage: dotctl cycle <wallpaper|waybar> <next|prev>  (try \`dotctl cycle --help\`)"

  load_state

  case "$target" in
    wallpaper)
      local verb
      case "$direction" in
        next) verb=forward;;
        prev) verb=backward;;
        *) die "cycle wallpaper: direction must be next|prev";;
      esac
      local script; script=$(cycle_script "$WALLPAPER")
      [[ -x "$script" ]] || die "missing $script"
      "$script" "$verb"
      log "cycle wallpaper $direction ($WALLPAPER)"
      ;;
    waybar)
      # 4-wide variant cycle within (WAYBAR_COLOR, WAYBAR_FONT); rotates STYLE × SCOPE
      local combos=(
        "pill full"
        "pill minimal"
        "console full"
        "console minimal"
      )
      local current="${WAYBAR_STYLE} ${WAYBAR_SCOPE}" i idx=0
      for i in "${!combos[@]}"; do
        [[ "${combos[$i]}" == "$current" ]] && { idx=$i; break; }
      done
      local count=${#combos[@]} next
      case "$direction" in
        next) next=$(( (idx + 1) % count ));;
        prev) next=$(( (idx - 1 + count) % count ));;
        *) die "cycle waybar: direction must be next|prev";;
      esac
      read -r WAYBAR_STYLE WAYBAR_SCOPE <<<"${combos[$next]}"
      save_state
      apply_waybar
      log "cycle waybar $direction → ${WAYBAR_STYLE}_${WAYBAR_SCOPE}"
      ;;
    *) die "cycle: target must be wallpaper|waybar";;
  esac
}

# ──────────────────────────────────────────────────────────────────────────────
#  `sync` - copy color (and font where applicable) from source to target
# ──────────────────────────────────────────────────────────────────────────────

# Accessors for an element's color/font; "-" if axis doesn't apply.
_element_color() {
  case "$1" in
    cava)                printf '%s\n' "$CAVA_COLOR";;
    kitty)               printf '%s\n' "$KITTY_COLOR";;
    mako)                printf '%s\n' "$MAKO_COLOR";;
    wofi)                printf '%s\n' "$WOFI_COLOR";;
    waybar)              printf '%s\n' "$WAYBAR_COLOR";;
    tty-clock|ttyclock)  printf '%s\n' "$TTYCLOCK_COLOR";;
    wallpaper)           printf '%s\n' "$WALLPAPER";;
    *) return 1;;
  esac
}

_element_font() {
  case "$1" in
    kitty)  printf '%s\n' "$KITTY_FONT";;
    mako)   printf '%s\n' "$MAKO_FONT";;
    wofi)   printf '%s\n' "$WOFI_FONT";;
    waybar) printf '%s\n' "$WAYBAR_FONT";;
    cava|tty-clock|ttyclock|wallpaper) printf '-\n';;
    *) return 1;;
  esac
}

_set_element_color() {
  local el="$1" color="$2"
  case "$el" in
    cava)
      validate_cava_color "$color" || die "sync: cava has no color $color"
      CAVA_COLOR="$color";;
    kitty)
      validate_kitty_color "$color" || die "sync: kitty has no color $color"
      KITTY_COLOR="$color";;
    mako)
      validate_mako_color "$color" || die "sync: mako has no color $color"
      MAKO_COLOR="$color";;
    wofi)
      validate_wofi_color "$color" || die "sync: wofi has no color $color"
      WOFI_COLOR="$color";;
    waybar)
      validate_waybar_color "$color" || die "sync: waybar has no color $color"
      WAYBAR_COLOR="$color";;
    tty-clock|ttyclock)
      ttyclock_available || die "sync: tty-clock not installed"
      validate_ttyclock_color "$color" || die "sync: tty-clock has no color $color"
      TTYCLOCK_COLOR="$color";;
    wallpaper)
      validate_wallpaper "$color" || die "sync: no wallpaper theme \`$color\`"
      WALLPAPER="$color";;
    *) die "sync: unknown element $el";;
  esac
}

_set_element_font() {
  local el="$1" font="$2"
  [[ "$font" == "-" ]] && return 0
  case "$el" in
    kitty)
      validate_kitty_font "$font" || die "sync: kitty has no font $font"
      KITTY_FONT="$font";;
    mako)
      validate_mako_font "$font" || die "sync: mako has no font $font"
      MAKO_FONT="$font";;
    wofi)
      validate_wofi_font "$font" || die "sync: wofi has no font $font"
      WOFI_FONT="$font";;
    waybar)
      validate_waybar_font "$font" || die "sync: waybar has no font $font"
      WAYBAR_FONT="$font";;
    cava|tty-clock|ttyclock|wallpaper) ;;  # no font axis
    *) die "sync: unknown element $el";;
  esac
}

cmd_sync() {
  local target="${1:-}" source="${2:-}"

  case "$target" in
    -h|--help|help|'')
      cat <<'EOF'
dotctl sync <target> <source>

Copy color (and font, where both have a font axis) from <source> to <target>.
Never copies style, scope, variant, decor, vpn, transparent, or opacity -
those stay on the target.

  target ∈ { cava, kitty, mako, wofi, waybar, tty-clock, wallpaper, all }
  source ∈ { cava, kitty, mako, wofi, waybar, tty-clock, wallpaper }

Elements without a font axis (cava, tty-clock, wallpaper) are sync-color-only.
When <target> is `all`, the <source> element itself is left untouched. tty-clock
is only reachable via sync when it was installed (see install.sh).

Examples:
  dotctl sync wallpaper waybar    # wallpaper follows waybar color
  dotctl sync all kitty           # every installed element + wallpaper take kitty's color+font
  dotctl sync waybar cava         # waybar color ← cava color (cava has no font)
  dotctl sync tty-clock kitty     # tty-clock palette follows kitty (no font axis)
EOF
      return 0;;
  esac

  [[ -n "$target" && -n "$source" ]] || die "usage: dotctl sync <target> <source>  (try \`dotctl sync --help\`)"

  load_state

  local src_color src_font
  src_color=$(_element_color "$source") || die "sync: unknown source element \`$source\`"
  src_font=$(_element_font "$source")

  if [[ "$target" == "all" ]]; then
    local el targets=( cava kitty mako wofi waybar wallpaper )
    # tty-clock joins `all` only when installed - skips it transparently
    # for users who opted out.
    ttyclock_available && targets+=( tty-clock )
    for el in "${targets[@]}"; do
      [[ "$el" == "$source" ]] && continue
      _set_element_color "$el" "$src_color" || warn "sync: skip $el (no match for $src_color)"
      _set_element_font  "$el" "$src_font"  || true
    done
  else
    _element_color "$target" >/dev/null || die "sync: unknown target element \`$target\`"
    _set_element_color "$target" "$src_color"
    _set_element_font  "$target" "$src_font"
  fi

  save_state

  if [[ "$target" == "all" ]]; then
    apply_all
  else
    apply_subset "$target"
  fi
  info "dotctl: synced $target ← $source ($src_color${src_font:+ / $src_font})"
}

# ──────────────────────────────────────────────────────────────────────────────
#  `configure` - p10k-style interactive wizard
# ──────────────────────────────────────────────────────────────────────────────

# prompt_select LABEL DEFAULT OPTION...
# Prints chosen value to stdout. Empty DEFAULT → first option.
# Each OPTION may be a plain value ("phoenix") or a "value|description"
# pair ("1|subtle - muted border, cool highlights") - the description is
# shown next to the number but is NOT part of the returned value.
prompt_select() {
  local label="$1" default="$2"; shift 2
  local raw=( "$@" )
  local values=() descs=() i opt choice default_idx=1

  for opt in "${raw[@]}"; do
    if [[ "$opt" == *"|"* ]]; then
      values+=( "${opt%%|*}" )
      descs+=(  "${opt#*|}" )
    else
      values+=( "$opt" )
      descs+=(  "" )
    fi
  done

  for i in "${!values[@]}"; do
    [[ "${values[$i]}" == "$default" ]] && default_idx=$(( i + 1 ))
  done

  # Top-level element prompts (label starts with "[") get a blank line of
  # breathing room above them; sub-prompts stay tight under their parent.
  [[ "$label" == \[* ]] && printf '\n' >&2
  printf '  %s\n' "$label" >&2
  for i in "${!values[@]}"; do
    opt="${values[$i]}"
    local suffix=''
    [[ -n "${descs[$i]}" ]] && suffix="  - ${descs[$i]}"
    if [[ "$opt" == "$default" ]]; then
      printf '    %2d) %s%s  (current)\n' $(( i + 1 )) "$opt" "$suffix" >&2
    else
      printf '    %2d) %s%s\n' $(( i + 1 )) "$opt" "$suffix" >&2
    fi
  done

  local count=${#values[@]}
  while :; do
    read -r -p "  pick 1-${count} [enter = ${default_idx}]: " choice
    choice="${choice:-$default_idx}"
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= count )); then
      printf '%s\n' "${values[$((choice - 1))]}"
      return 0
    fi
    printf '    invalid - enter a number between 1 and %d\n' "$count" >&2
  done
}

# prompt_font_size LABEL DEFAULT
# Walks the FONT_SIZE_LADDER plus a "custom..." entry. Custom opens a free-form
# read loop validated by validate_font_size. Returns the chosen numeric value.
prompt_font_size() {
  local label="$1" default="$2"
  local opts=( "${FONT_SIZE_LADDER[@]}" "custom|enter a different value" )
  local picked
  picked=$(prompt_select "$label" "$default" "${opts[@]}")
  if [[ "$picked" == "custom" ]]; then
    local val
    while :; do
      read -r -p "  custom font size [4-72]: " val
      if validate_font_size "$val"; then
        printf '%s\n' "$val"
        return 0
      fi
      printf '    invalid - must be a number in [4, 72]\n' >&2
    done
  else
    printf '%s\n' "$picked"
  fi
}

# prompt_opacity LABEL DEFAULT - picker from OPACITY_LADDER plus custom
prompt_opacity() {
  local label="$1" default="$2"
  local opts=( "${OPACITY_LADDER[@]}" "custom|enter a different value" )
  local picked
  picked=$(prompt_select "$label" "$default" "${opts[@]}")
  if [[ "$picked" == "custom" ]]; then
    local val
    while :; do
      read -r -p "  custom opacity [0.0-1.0]: " val
      if validate_waybar_opacity "$val"; then
        printf '%s\n' "$val"
        return 0
      fi
      printf '    invalid - must be a number in [0, 1]\n' >&2
    done
  else
    printf '%s\n' "$picked"
  fi
}

cmd_configure() {
  local preset_name='' arg
  while (( $# > 0 )); do
    case "$1" in
      --preset) preset_name="${2:-}"; shift 2;;
      -h|--help)
        cat <<'EOF'
dotctl configure [--preset <name>]

Interactive wizard. Walks every installed element:
  cava → kitty → mako → wofi → waybar → [tty-clock] → wallpaper

tty-clock is included only when the installer set it up. Each prompt
defaults to the current value (or preset value with --preset). Ends with
a summary, an apply confirmation, and an optional save-as-preset step.
EOF
        return 0;;
      *) die "configure: unknown flag \`$1\`";;
    esac
  done

  info ""
  info "  dotctl configure"
  info "  ───────────────────"

  if state_exists; then
    load_state
    info "  Current state loaded as defaults."
  else
    info "  First-time setup - no current state."
    # Seed empty defaults; first option in each prompt will be picked.
    local k; for k in "${STATE_KEYS[@]}"; do declare -g "$k="; done
    # Font sizes need numeric defaults so the ladder highlights a sensible pick.
    KITTY_FONT_SIZE="$DEFAULT_KITTY_FONT_SIZE"
    MAKO_FONT_SIZE="$DEFAULT_MAKO_FONT_SIZE"
    WOFI_FONT_SIZE="$DEFAULT_WOFI_FONT_SIZE"
    WAYBAR_FONT_SIZE="$DEFAULT_WAYBAR_FONT_SIZE"
    WAYBAR_DECOR="$DEFAULT_WAYBAR_DECOR"
    WAYBAR_VPN="$DEFAULT_WAYBAR_VPN"
    WAYBAR_TRANSPARENT="$DEFAULT_WAYBAR_TRANSPARENT"
    WAYBAR_OPACITY="$DEFAULT_WAYBAR_OPACITY"
    WAYBAR_LAUNCHER_LOGO="$DEFAULT_WAYBAR_LAUNCHER_LOGO"
    HYPR_EFFECT="$DEFAULT_HYPR_EFFECT"
  fi

  if [[ -n "$preset_name" ]]; then
    _load_preset_into_state "$preset_name"
    info "  Preset \`$preset_name\` loaded as defaults."
  fi

  # Discover options per element
  local cava_colors kitty_colors kitty_fonts mako_colors mako_fonts
  local wofi_colors wofi_fonts wofi_variants ttyclock_colors
  local waybar_colors waybar_fonts waybar_styles waybar_scopes waybar_decors waybar_vpns waybar_transparents waybar_opacities hypr_effects
  local wallpapers

  mapfile -t cava_colors    < <(detect_cava_colors)
  mapfile -t kitty_colors   < <(detect_kitty_colors)
  mapfile -t kitty_fonts    < <(detect_kitty_fonts)
  mapfile -t mako_colors    < <(detect_mako_colors)
  mapfile -t mako_fonts     < <(detect_mako_fonts)
  mapfile -t wofi_colors    < <(detect_wofi_colors)
  mapfile -t wofi_fonts     < <(detect_wofi_fonts)
  mapfile -t wofi_variants  < <(detect_wofi_variants)
  mapfile -t waybar_colors  < <(detect_waybar_colors)
  mapfile -t waybar_fonts   < <(detect_waybar_fonts)
  mapfile -t waybar_styles  < <(detect_waybar_styles)
  mapfile -t waybar_scopes  < <(detect_waybar_scopes)
  mapfile -t waybar_decors  < <(detect_waybar_decors)
  mapfile -t waybar_vpns    < <(detect_waybar_vpns)
  mapfile -t waybar_transparents < <(detect_waybar_transparents)
  mapfile -t waybar_opacities    < <(detect_waybar_opacities)
  mapfile -t hypr_effects        < <(detect_hypr_effects)
  mapfile -t ttyclock_colors     < <(detect_ttyclock_colors)
  mapfile -t wallpapers     < <(detect_wallpapers)

  (( ${#cava_colors[@]}   > 0 )) || die "no cava colors detected in $CAVA_DIR"
  (( ${#kitty_colors[@]}  > 0 )) || die "no kitty colors detected in $KITTY_DIR"
  (( ${#mako_colors[@]}   > 0 )) || die "no mako colors detected in $MAKO_DIR"
  (( ${#wofi_colors[@]}   > 0 )) || die "no wofi colors detected in $WOFI_DIR"
  (( ${#waybar_colors[@]} > 0 )) || die "no waybar colors detected in $WAYBAR_DIR"
  (( ${#wallpapers[@]}    > 0 )) || die "no wallpaper themes detected in $WALLPAPER_ROOT (with matching cycle scripts)"

  # Total step count in prompt labels adapts to whether tty-clock is
  # installed - 6 without, 7 with.
  local total=6
  ttyclock_available && total=7

  CAVA_COLOR=$(prompt_select      "[1/$total] cava color"               "$CAVA_COLOR"   "${cava_colors[@]}")

  KITTY_COLOR=$(prompt_select     "[2/$total] kitty color"              "$KITTY_COLOR"  "${kitty_colors[@]}")
  KITTY_FONT=$(prompt_select      "      kitty font"               "$KITTY_FONT"   "${kitty_fonts[@]}")
  KITTY_FONT_SIZE=$(prompt_font_size "      kitty font size"          "$KITTY_FONT_SIZE")

  MAKO_COLOR=$(prompt_select      "[3/$total] mako color"               "$MAKO_COLOR"   "${mako_colors[@]}")
  MAKO_FONT=$(prompt_select       "      mako font"                "$MAKO_FONT"    "${mako_fonts[@]}")
  MAKO_FONT_SIZE=$(prompt_font_size  "      mako font size"           "$MAKO_FONT_SIZE")

  WOFI_COLOR=$(prompt_select      "[4/$total] wofi color"               "$WOFI_COLOR"   "${wofi_colors[@]}")
  WOFI_FONT=$(prompt_select       "      wofi font"                "$WOFI_FONT"    "${wofi_fonts[@]}")
  WOFI_FONT_SIZE=$(prompt_font_size  "      wofi font size"           "$WOFI_FONT_SIZE")

  # Build wofi variant options with descriptions. detect_wofi_variants returns
  # plain numbers; we tag known variants with a human-readable hint and leave
  # anything else (if someone adds a third) undescribed.
  local wv_opts=() v desc
  for v in "${wofi_variants[@]}"; do
    case "$v" in
      1) desc="subtle - muted border, cool/neutral accent";;
      2) desc="punchy - bold border, warm/contrast accent";;
      *) desc="";;
    esac
    if [[ -n "$desc" ]]; then
      wv_opts+=( "${v}|${desc}" )
    else
      wv_opts+=( "$v" )
    fi
  done
  WOFI_VARIANT=$(prompt_select    "      wofi variant"             "$WOFI_VARIANT" "${wv_opts[@]}")

  WAYBAR_COLOR=$(prompt_select      "[5/$total] waybar color"             "$WAYBAR_COLOR" "${waybar_colors[@]}")
  WAYBAR_FONT=$(prompt_select       "      waybar font"              "$WAYBAR_FONT"  "${waybar_fonts[@]}")
  WAYBAR_FONT_SIZE=$(prompt_font_size  "      waybar font size"         "$WAYBAR_FONT_SIZE")
  WAYBAR_STYLE=$(prompt_select      "      waybar style"             "$WAYBAR_STYLE" "${waybar_styles[@]}")
  WAYBAR_SCOPE=$(prompt_select      "      waybar scope"             "$WAYBAR_SCOPE" "${waybar_scopes[@]}")
  WAYBAR_DECOR=$(prompt_select      "      waybar decor"             "$WAYBAR_DECOR" "${waybar_decors[@]}")
  if waybar_vpn_available; then
    WAYBAR_VPN=$(prompt_select      "      waybar vpn module"        "$WAYBAR_VPN"   "${waybar_vpns[@]}")
  else
    WAYBAR_VPN=off
    info "      waybar vpn module: skipped - vpnctl / vpn-status-indicator not on PATH"
  fi
  WAYBAR_TRANSPARENT=$(prompt_select "      waybar transparent bg"    "$WAYBAR_TRANSPARENT" "${waybar_transparents[@]}")
  WAYBAR_OPACITY=$(prompt_opacity   "      waybar bg opacity"         "$WAYBAR_OPACITY")
  HYPR_EFFECT=$(prompt_select       "      hypr window effect"        "$HYPR_EFFECT"  "${hypr_effects[@]}")

  # Launcher logo - tagged with distro pretty-names so the prompt reads
  # like a distro picker, but the stored value is the bare key.
  local wl_opts=() l
  for l in "${WAYBAR_LAUNCHER_LOGOS[@]}"; do
    wl_opts+=( "${l}|${WAYBAR_LAUNCHER_NAMES[$l]}" )
  done
  WAYBAR_LAUNCHER_LOGO=$(prompt_select "      waybar launcher logo" "$WAYBAR_LAUNCHER_LOGO" "${wl_opts[@]}")

  if ttyclock_available; then
    # Default to the current waybar color so first-time users get a coherent
    # theme without an extra decision. Existing state is preserved.
    : "${TTYCLOCK_COLOR:=$WAYBAR_COLOR}"
    TTYCLOCK_COLOR=$(prompt_select "[6/$total] tty-clock color"       "$TTYCLOCK_COLOR" "${ttyclock_colors[@]}")
    WALLPAPER=$(prompt_select      "[7/$total] wallpaper theme"       "$WALLPAPER"    "${wallpapers[@]}")
  else
    WALLPAPER=$(prompt_select      "[6/$total] wallpaper theme"       "$WALLPAPER"    "${wallpapers[@]}")
  fi

  # Summary
  info ""
  info "  ── summary ──"
  printf '  %-10s %s\n' "cava"      "$CAVA_COLOR"
  printf '  %-10s %s / %s / size %s\n' "kitty" "$KITTY_COLOR" "$KITTY_FONT" "$KITTY_FONT_SIZE"
  printf '  %-10s %s / %s / size %s\n' "mako"  "$MAKO_COLOR" "$MAKO_FONT" "$MAKO_FONT_SIZE"
  printf '  %-10s %s / %s / size %s / variant %s\n' "wofi" "$WOFI_COLOR" "$WOFI_FONT" "$WOFI_FONT_SIZE" "$WOFI_VARIANT"
  printf '  %-10s %s / %s / size %s / %s_%s / decor %s / vpn %s / transparent %s (%s) / logo %s\n' "waybar" "$WAYBAR_COLOR" "$WAYBAR_FONT" "$WAYBAR_FONT_SIZE" "$WAYBAR_STYLE" "$WAYBAR_SCOPE" "$WAYBAR_DECOR" "$WAYBAR_VPN" "$WAYBAR_TRANSPARENT" "$WAYBAR_OPACITY" "$WAYBAR_LAUNCHER_LOGO"
  ttyclock_available && printf '  %-10s %s\n' "tty-clock" "$TTYCLOCK_COLOR"
  printf '  %-10s effect %s\n' "hypr" "$HYPR_EFFECT"
  printf '  %-10s %s\n' "wallpaper" "$WALLPAPER"
  info ""

  if confirm "  Apply now and save state?" y; then
    save_state
    apply_all
    info "  dotctl: applied."
  else
    info "  Aborted. State not written."
    return 0
  fi

  if confirm "  Save as preset?" n; then
    local name
    read -r -p "  preset name: " name
    [[ -n "$name" ]] || { warn "empty name, skipping"; return 0; }
    _save_preset "$name"
    info "  preset saved: $name"
  fi
}

# ──────────────────────────────────────────────────────────────────────────────
#  Presets
# ──────────────────────────────────────────────────────────────────────────────

_preset_path() { printf '%s/%s.conf\n' "$PRESET_DIR" "$1"; }

_save_preset() {
  local name="$1" path
  path=$(_preset_path "$name")
  mkdir -p "$PRESET_DIR"
  {
    printf '# dotctl preset - %s\n' "$name"
    printf '# created %s\n' "$(date '+%F %T')"
    local k
    for k in "${STATE_KEYS[@]}"; do
      printf '%s=%q\n' "$k" "${!k}"
    done
  } > "$path"
}

_load_preset_into_state() {
  local name="$1" path
  path=$(_preset_path "$name")
  [[ -f "$path" ]] || die "preset not found: $name  ($path)"
  # shellcheck disable=SC1090
  source "$path"
  # Presets written before a key was added are missing it - fall back to
  # defaults so apply_* doesn't see an empty variable.
  : "${KITTY_FONT_SIZE:=$DEFAULT_KITTY_FONT_SIZE}"
  : "${MAKO_FONT_SIZE:=$DEFAULT_MAKO_FONT_SIZE}"
  : "${WOFI_FONT_SIZE:=$DEFAULT_WOFI_FONT_SIZE}"
  : "${WAYBAR_FONT_SIZE:=$DEFAULT_WAYBAR_FONT_SIZE}"
  : "${WAYBAR_DECOR:=$DEFAULT_WAYBAR_DECOR}"
  : "${WAYBAR_VPN:=$DEFAULT_WAYBAR_VPN}"
  : "${WAYBAR_TRANSPARENT:=$DEFAULT_WAYBAR_TRANSPARENT}"
  : "${WAYBAR_OPACITY:=$DEFAULT_WAYBAR_OPACITY}"
  : "${WAYBAR_LAUNCHER_LOGO:=$DEFAULT_WAYBAR_LAUNCHER_LOGO}"
  : "${HYPR_EFFECT:=$DEFAULT_HYPR_EFFECT}"
  case "$WAYBAR_STYLE" in zsh) WAYBAR_STYLE="console";; bubble) WAYBAR_STYLE="pill";; esac
}

cmd_preset() {
  local sub="${1:-}"
  case "$sub" in
    save)
      local name="${2:-}"
      [[ -n "$name" ]] || die "usage: dotctl preset save <name>"
      load_state
      _save_preset "$name"
      info "preset saved: $(_preset_path "$name")"
      ;;
    load)
      local name="${2:-}"
      [[ -n "$name" ]] || die "usage: dotctl preset load <name>"
      load_state
      _load_preset_into_state "$name"
      save_state
      apply_all
      info "preset loaded: $name"
      ;;
    list)
      if [[ -d "$PRESET_DIR" ]]; then
        ls -1 "$PRESET_DIR" 2>/dev/null | sed 's/\.conf$//'
      fi
      ;;
    show)
      local name="${2:-}"
      [[ -n "$name" ]] || die "usage: dotctl preset show <name>"
      local path; path=$(_preset_path "$name")
      [[ -f "$path" ]] || die "preset not found: $name"
      cat "$path"
      ;;
    delete|rm)
      local name="${2:-}"
      [[ -n "$name" ]] || die "usage: dotctl preset delete <name>"
      local path; path=$(_preset_path "$name")
      [[ -f "$path" ]] || die "preset not found: $name"
      rm -f "$path"
      info "preset deleted: $name"
      ;;
    ''|help|-h|--help)
      cat <<'EOF'
dotctl preset <save|load|list|show|delete> [name]

  save <name>     Snapshot current state as a preset
  load <name>     Apply a preset (same effect as set --preset <name>)
  list            List saved presets
  show <name>     Print a preset's contents
  delete <name>   Remove a preset

Presets live under ~/.config/dotctl/presets/<name>.conf
EOF
      ;;
    *) die "preset: unknown subcommand \`$sub\`";;
  esac
}

# ──────────────────────────────────────────────────────────────────────────────
#  Cycle script generation - shared by `new wallpaper` and `scan`
# ──────────────────────────────────────────────────────────────────────────────

# Resolve the cycle-hyprpaper template path. Installed location is
# $CYCLE_DIR/_cycle-hyprpaper.template. Falls back to the source dir next to
# this script when running uninstalled (stage/cycle/_cycle-hyprpaper.template).
_template_path() {
  [[ -f "$CYCLE_TEMPLATE" ]] && { printf '%s\n' "$CYCLE_TEMPLATE"; return 0; }
  local self_dir
  self_dir=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
  if [[ -f "$self_dir/cycle/_cycle-hyprpaper.template" ]]; then
    printf '%s\n' "$self_dir/cycle/_cycle-hyprpaper.template"
    return 0
  fi
  die "cycle template not found. Run install.sh, or place it at $CYCLE_TEMPLATE"
}

# Render a cycle-hyprpaper-<color> script to stdout.
#   $1 - color (theme name)
#   $2 - optional images block. When provided, the IMAGES=( ) lines from the
#        template are replaced with this block. The block must NOT include the
#        opening `IMAGES=(` or closing `)` - just the inner lines, one per line.
#        When empty (or omitted), the template's placeholder comment is left in
#        place for human editing.
_render_cycle_script() {
  local color="$1" images_block="${2:-}"
  local template
  template=$(_template_path)

  if [[ -z "$images_block" ]]; then
    sed "s/__COLOR__/$color/g" "$template"
    return 0
  fi

  sed "s/__COLOR__/$color/g" "$template" | awk -v block="$images_block" '
    /^IMAGES=\(/ { print; print block; in_block=1; next }
    in_block && /^\)/ { print; in_block=0; next }
    in_block { next }
    { print }
  '
}

# Build an IMAGES=( ) inner block from the contents of a wallpaper directory.
# Globs common image extensions (case-insensitive), sorts alphabetically, emits
# one quoted basename per line indented two spaces. Empty dir → placeholder
# comment.
_build_images_block() {
  local dir="$1"
  local -a found=()
  local f
  shopt -s nullglob nocaseglob
  for f in "$dir"/*.jpg "$dir"/*.jpeg "$dir"/*.png "$dir"/*.webp "$dir"/*.gif "$dir"/*.bmp "$dir"/*.jxl; do
    [[ -f "$f" ]] && found+=( "$(basename "$f")" )
  done
  shopt -u nullglob nocaseglob

  if (( ${#found[@]} == 0 )); then
    printf '  # no images found at scan time - drop files into the wallpaper dir then re-run dotctl scan\n'
    return 0
  fi

  # Sort alphabetically (LC_ALL=C for stable byte order).
  local sorted
  sorted=$(printf '%s\n' "${found[@]}" | LC_ALL=C sort)
  printf '%s\n' "$sorted" | sed 's/^/  "/; s/$/"/'
}

# Number of image files _build_images_block would emit (used for status output).
_count_images() {
  local dir="$1" n=0 f
  shopt -s nullglob nocaseglob
  for f in "$dir"/*.jpg "$dir"/*.jpeg "$dir"/*.png "$dir"/*.webp "$dir"/*.gif "$dir"/*.bmp "$dir"/*.jxl; do
    [[ -f "$f" ]] && (( ++n ))
  done
  shopt -u nullglob nocaseglob
  printf '%d\n' "$n"
}

# Extract the list of basenames from IMAGES=( ) in an existing cycle script.
# Prints one unquoted basename per line.
_script_images() {
  local script="$1"
  sed -n '/^IMAGES=(/,/^)/{ /^IMAGES=(/d; /^)/d; p; }' "$script" \
    | sed 's/^[[:space:]]*"//; s/"[[:space:]]*$//' \
    | grep -v '^#' || true
}

# List image basenames on disk for a wallpaper directory (one per line, sorted).
_disk_images() {
  local dir="$1" f
  shopt -s nullglob nocaseglob
  for f in "$dir"/*.jpg "$dir"/*.jpeg "$dir"/*.png "$dir"/*.webp "$dir"/*.gif "$dir"/*.bmp "$dir"/*.jxl; do
    [[ -f "$f" ]] && basename "$f"
  done
  shopt -u nullglob nocaseglob
}

# Patch an existing cycle script's IMAGES=() to append new images and remove
# stale entries while preserving the hand-curated order of existing entries.
_update_images_in_script() {
  local script="$1" dir="$2"
  local -a on_disk=() in_script=() new_imgs=()

  mapfile -t on_disk  < <(_disk_images "$dir" | LC_ALL=C sort -u)
  mapfile -t in_script < <(_script_images "$script")

  # Build a set of images currently on disk for fast lookup.
  local -A disk_set=()
  local img
  for img in "${on_disk[@]}"; do disk_set["$img"]=1; done

  # Build a set of images already in the script.
  local -A script_set=()
  for img in "${in_script[@]}"; do script_set["$img"]=1; done

  # New images = on disk but not in script.
  for img in "${on_disk[@]}"; do
    [[ -z "${script_set[$img]:-}" ]] && new_imgs+=( "$img" )
  done

  # Rebuild the block: keep existing entries that still exist on disk (in their
  # original order), then append new images (sorted alphabetically).
  local -a merged=()
  for img in "${in_script[@]}"; do
    [[ -n "${disk_set[$img]:-}" ]] && merged+=( "$img" )
  done
  merged+=( "${new_imgs[@]}" )

  # Format the new block.
  local block
  block=$(printf '%s\n' "${merged[@]}" | sed 's/^/  "/; s/$/"/')

  # Replace the IMAGES block in the script.
  awk -v block="$block" '
    /^IMAGES=\(/ { print; print block; in_block=1; next }
    in_block && /^\)/ { print; in_block=0; next }
    in_block { next }
    { print }
  ' "$script" > "${script}.tmp" && mv "${script}.tmp" "$script"
  chmod +x "$script"
}

# ──────────────────────────────────────────────────────────────────────────────
#  `new wallpaper` - scaffold a new wallpaper theme
# ──────────────────────────────────────────────────────────────────────────────

cmd_new() {
  local kind="${1:-}" name="${2:-}"

  case "$kind" in
    -h|--help|help|'')
      cat <<'EOF'
dotctl new wallpaper <name>

Scaffold a new wallpaper theme. Creates:
  ~/Pictures/dotctl/wallpapers/<name>/
  ~/.config/dotctl/cycle/cycle-hyprpaper-<name>

The cycle script is rendered from the 4-verb template with __COLOR__
replaced by <name>. Populate IMAGES=( ) by hand for curated ordering, or
drop images into the directory and run `dotctl scan` to auto-populate in
alphabetical order.

<name> must match [a-z0-9_]+. The script refuses to overwrite an existing
cycle script; delete or rename it first if you want a fresh scaffold.

Examples:
  dotctl new wallpaper forest
  cp ~/Downloads/*.jpg ~/Pictures/dotctl/wallpapers/forest/
  $EDITOR ~/.config/dotctl/cycle/cycle-hyprpaper-forest   # edit IMAGES=()
  dotctl set -w forest
EOF
      return 0;;
  esac

  [[ "$kind" == "wallpaper" && -n "$name" ]] || die "usage: dotctl new wallpaper <name>  (try \`dotctl new --help\`)"
  [[ "$name" =~ ^[a-z0-9_]+$ ]] || die "wallpaper name must match [a-z0-9_]+"

  local dir="$WALLPAPER_ROOT/$name"
  local script; script=$(cycle_script "$name")

  [[ -e "$script" ]] && die "$script already exists"
  mkdir -p "$dir" "$CYCLE_DIR"
  _render_cycle_script "$name" > "$script"
  chmod +x "$script"

  info "created:"
  info "  $dir/"
  info "  $script"
  info ""
  info "next:"
  info "  1. drop image files into $dir/"
  info "  2. edit $script and populate the IMAGES=( ) array with the desired cycle order"
  info "     (or run \`dotctl scan\` once images are in place to auto-populate)"
  info "  3. dotctl set -w $name   (or pick it in configure)"
}

# ──────────────────────────────────────────────────────────────────────────────
#  `scan` - auto-generate cycle scripts for any wallpaper dirs missing them
# ──────────────────────────────────────────────────────────────────────────────

cmd_scan() {
  local prefix="$WALLPAPER_ROOT" dry_run='' force='' update=''
  while (( $# > 0 )); do
    case "$1" in
      --dry-run)  dry_run=1; shift;;
      --force)    force=1; shift;;
      --update)   update=1; shift;;
      --prefix)   prefix="$2"; shift 2;;
      -h|--help)
        cat <<'EOF'
dotctl scan [OPTIONS]

Walks the wallpaper root looking for theme directories without a matching
cycle-hyprpaper-<dir> script. Generates the missing scripts from the template
and populates IMAGES=( ) from the directory's contents (alphabetical order).

Directory names must match [a-z0-9_]+. Anything else is skipped with a
warning. Existing scripts are preserved unless --force or --update is given.

When run without --force or --update, existing directories that have changed
(new or removed images) are flagged in the output.

OPTIONS
  --prefix <path>   Scan this directory instead of $WALLPAPER_ROOT.
                    Generated scripts will hardcode this prefix as
                    WALLPAPER_DIR, so you can scan a non-canonical location
                    and have the scripts work there directly.
  --dry-run         Print what would be created/updated, write nothing.
  --update          Update existing scripts with new images. Preserves
                    hand-curated ordering of existing entries, appends new
                    images at the end, and removes entries for deleted files.
  --force           Regenerate scripts even if they already exist
                    (replaces hand-curated IMAGES=() ordering - be careful).

EXAMPLES
  dotctl scan
  dotctl scan --dry-run
  dotctl scan --update
  dotctl scan --prefix ~/Downloads/wallpaper-pack
  dotctl scan --force
EOF
        return 0;;
      *) die "scan: unknown flag \`$1\` - try \`dotctl scan --help\`";;
    esac
  done

  [[ -d "$prefix" ]] || die "scan: $prefix does not exist or is not a directory"

  info "scanning $prefix/"
  local created=0 skipped=0 invalid=0 forced=0 updated=0 stale=0
  local dir name target images_block n existed

  for dir in "$prefix"/*/; do
    [[ -d "$dir" ]] || continue
    name=$(basename "$dir")

    if [[ ! "$name" =~ ^[a-z0-9_]+$ ]]; then
      printf '  %-20s skip - invalid name (must match [a-z0-9_]+)\n' "$name" >&2
      (( ++invalid ))
      continue
    fi

    mkdir -p "$CYCLE_DIR"
    target=$(cycle_script "$name")
    existed=0
    [[ -e "$target" ]] && existed=1

    n=$(_count_images "$dir")

    # ── existing script: --update merges, --force regenerates, default reports ──
    if (( existed == 1 )) && [[ -z "$force" ]]; then
      if [[ -n "$update" ]]; then
        # Compute new/removed image counts for status output.
        local -a _disk_list _script_list _new _removed
        _disk_list=() _script_list=() _new=() _removed=()
        mapfile -t _disk_list   < <(_disk_images "$dir" | LC_ALL=C sort -u)
        mapfile -t _script_list < <(_script_images "$target")

        local -A _disk_set _script_set
        _disk_set=() _script_set=()
        local _img
        for _img in "${_disk_list[@]}"; do _disk_set["$_img"]=1; done
        for _img in "${_script_list[@]}"; do _script_set["$_img"]=1; done
        for _img in "${_disk_list[@]}"; do
          [[ -z "${_script_set[$_img]:-}" ]] && _new+=( "$_img" )
        done
        for _img in "${_script_list[@]}"; do
          [[ -z "${_disk_set[$_img]:-}" ]] && _removed+=( "$_img" )
        done

        if (( ${#_new[@]} == 0 && ${#_removed[@]} == 0 )); then
          printf '  %-20s up to date (%s images)\n' "$name" "$n"
          (( ++skipped ))
          continue
        fi

        if [[ -n "$dry_run" ]]; then
          printf '  %-20s DRY-RUN would update cycle-hyprpaper-%s (+%s new, -%s removed)\n' \
            "$name" "$name" "${#_new[@]}" "${#_removed[@]}"
          continue
        fi

        _update_images_in_script "$target" "$dir"
        printf '  %-20s updated cycle-hyprpaper-%s (+%s new, -%s removed, %s total)\n' \
          "$name" "$name" "${#_new[@]}" "${#_removed[@]}" "$n"
        (( ++updated ))
        continue
      fi

      # Default (no --force, no --update): check for changes and report.
      local _disk_n _script_n
      _disk_n=$n
      _script_n=$(wc -l < <(_script_images "$target"))
      _script_n=${_script_n// /}
      if [[ "$_disk_n" != "$_script_n" ]]; then
        printf '  %-20s skip - script exists (%s on disk, %s in script - run with --update)\n' \
          "$name" "$_disk_n" "$_script_n"
        (( ++stale ))
      else
        printf '  %-20s skip - script exists\n' "$name"
      fi
      (( ++skipped ))
      continue
    fi

    # ── new directory or --force: generate from scratch ──
    if [[ -n "$dry_run" ]]; then
      if (( existed == 1 )); then
        printf '  %-20s DRY-RUN would REGENERATE cycle-hyprpaper-%s (%s images)\n' "$name" "$name" "$n"
      else
        printf '  %-20s DRY-RUN would create cycle-hyprpaper-%s (%s images)\n' "$name" "$name" "$n"
      fi
      continue
    fi

    images_block=$(_build_images_block "$dir")
    _render_cycle_script "$name" "$images_block" > "$target"

    # When --prefix is non-default, rewrite WALLPAPER_DIR in the generated
    # script so it points to the literal scan path rather than the canonical
    # WALLPAPER_ROOT/<name>.
    if [[ "$prefix" != "$WALLPAPER_ROOT" ]]; then
      sed -i -E "s|^WALLPAPER_DIR=.*|WALLPAPER_DIR=\"$prefix/$name\"|" "$target"
    fi

    chmod +x "$target"

    if (( existed == 1 )); then
      printf '  %-20s regenerated cycle-hyprpaper-%s (%s images)\n' "$name" "$name" "$n"
      (( ++forced ))
    else
      printf '  %-20s created cycle-hyprpaper-%s (%s images)\n' "$name" "$name" "$n"
      (( ++created ))
    fi
  done

  info ""
  if [[ -n "$dry_run" ]]; then
    info "dry-run complete (no files written)"
  else
    local summary="created $created, skipped $skipped, invalid $invalid"
    (( forced  > 0 )) && summary+=", regenerated $forced"
    (( updated > 0 )) && summary+=", updated $updated"
    (( stale   > 0 )) && summary+=", stale $stale (run --update to sync)"
    info "$summary"
  fi
}

# ──────────────────────────────────────────────────────────────────────────────
#  apply / watch - re-apply from (a possibly hand-edited) config file
# ──────────────────────────────────────────────────────────────────────────────

cmd_apply() {
  case "${1:-}" in
    -h|--help|help)
      cat <<'EOF'
dotctl apply

Re-read ~/.config/dotctl/config and re-apply every element (cava, kitty,
mako, wofi, waybar, hypr, wallpaper). Use after hand-editing the state
file, or as a catch-up when something in the live configs drifted.

Equivalent to `dotctl set` with no behavior change; does not write state.
EOF
      return 0;;
  esac

  load_state
  apply_all
  log "apply: full config from $STATE_FILE"
  info "dotctl: applied"
}

cmd_watch() {
  case "${1:-}" in
    -h|--help|help)
      cat <<'EOF'
dotctl watch

Watch ~/.config/dotctl/config and auto-apply on save. Uses inotifywait(1)
when available; falls back to 1-second mtime polling otherwise. Handy for
editing the state file in a second terminal and seeing changes live.

Ctrl-C to stop. No arguments.
EOF
      return 0;;
  esac

  local watch_dir watch_base
  watch_dir=$(dirname "$STATE_FILE")
  watch_base=$(basename "$STATE_FILE")
  mkdir -p "$watch_dir"

  info "dotctl: watching $STATE_FILE (Ctrl-C to stop)"

  _watch_apply() {
    if load_state 2>/dev/null; then
      if apply_all >/dev/null 2>&1; then
        log "watch: applied from $STATE_FILE"
        info "dotctl: applied $(date '+%H:%M:%S')"
      else
        warn "watch: apply failed"
      fi
    else
      warn "watch: invalid or incomplete $STATE_FILE - edit and save again"
    fi
  }

  if command -v inotifywait >/dev/null 2>&1; then
    # Monitor the dir (not the file) so atomic editor saves (temp + rename)
    # survive inode changes. Filter events by filename.
    inotifywait -qq -m -e close_write,moved_to "$watch_dir" \
      | while read -r _ _ file; do
          [[ "$file" == "$watch_base" ]] || continue
          _watch_apply
        done
  else
    warn "inotifywait not found - using 1s mtime polling"
    local last=0 cur=0
    [[ -f "$STATE_FILE" ]] && last=$(stat -c %Y "$STATE_FILE" 2>/dev/null || echo 0)
    while :; do
      sleep 1
      [[ -f "$STATE_FILE" ]] || continue
      cur=$(stat -c %Y "$STATE_FILE" 2>/dev/null || echo 0)
      if [[ "$cur" != "$last" ]]; then
        last="$cur"
        _watch_apply
      fi
    done
  fi
}

