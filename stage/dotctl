#!/bin/bash
# dotctl - unified theme controller for cava, kitty, mako, wofi, waybar, tty-clock, hyprpaper.
#
#   dotctl help            for full usage
#   dotctl configure       first-time interactive setup (required before any other command)
#   dotctl show            pretty-print current state
#   dotctl set [flags]     change one or more axes
#   dotctl cycle ...       step a wallpaper or waybar cycle (keybind entry points)
#   dotctl sync ...        copy color/font from one element to another
#   dotctl preset ...      save / load / list named presets
#   dotctl list <axis>     list valid values for an axis
#   dotctl new wallpaper N scaffold a new wallpaper theme (dir + cycle script)

set -euo pipefail

# Ensure per-color cycle scripts are reachable when invoked from Hyprland
# keybinds (whose environment doesn't inherit ~/.local/bin from shell init).
export PATH="$HOME/.local/bin:$PATH"

# ──────────────────────────────────────────────────────────────────────────────
#  Paths / constants
# ──────────────────────────────────────────────────────────────────────────────

readonly CONFIG_ROOT="$HOME/.config"
readonly CAVA_DIR="$CONFIG_ROOT/cava"
readonly KITTY_DIR="$CONFIG_ROOT/kitty"
readonly MAKO_DIR="$CONFIG_ROOT/mako"
readonly WOFI_DIR="$CONFIG_ROOT/wofi"
readonly WAYBAR_DIR="$CONFIG_ROOT/waybar"
# tty-clock is optional: the installer only creates $TTYCLOCK_DIR when the
# user opts in, so all tty-clock paths are guarded by `ttyclock_available`.
readonly TTYCLOCK_DIR="$CONFIG_ROOT/tty-clock"
readonly HYPR_DIR="$CONFIG_ROOT/hypr"
readonly HYPR_COLORS_FILE="$HYPR_DIR/dotctl-colors.conf"
readonly HYPR_COLORS_TEMPLATE="$HOME/.local/share/dotctl/dotctl-colors.conf.tmpl"
readonly WALLPAPER_ROOT="$HOME/Pictures/dotctl/wallpapers"

readonly CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/dotctl"
readonly STATE_DIR="$CONFIG_ROOT/dotctl"
readonly STATE_FILE="$STATE_DIR/config"
readonly STATE_LOCK="$CACHE_DIR/lock"
readonly LEGACY_STATE_FILE="$CACHE_DIR/state"
readonly PRESET_DIR="$STATE_DIR/presets"
readonly CYCLE_DIR="$STATE_DIR/cycle"
readonly CYCLE_TEMPLATE="$CYCLE_DIR/_cycle-hyprpaper.template"
readonly LOG_FILE="/tmp/dotctl.log"

# Resolve the absolute path to cycle-hyprpaper-<theme> for the current
# install. Scripts live under ~/.config/dotctl/cycle/ and are NOT on PATH
# by default - always call them via this helper.
cycle_script() { printf '%s/cycle-hyprpaper-%s\n' "$CYCLE_DIR" "$1"; }

readonly STATE_KEYS=(
  CAVA_COLOR
  KITTY_COLOR   KITTY_FONT   KITTY_FONT_SIZE
  MAKO_COLOR    MAKO_FONT    MAKO_FONT_SIZE
  WOFI_COLOR    WOFI_FONT    WOFI_FONT_SIZE  WOFI_VARIANT
  WAYBAR_COLOR  WAYBAR_FONT  WAYBAR_FONT_SIZE WAYBAR_STYLE WAYBAR_SCOPE WAYBAR_DECOR WAYBAR_VPN WAYBAR_TRANSPARENT WAYBAR_OPACITY WAYBAR_LAUNCHER_LOGO
  TTYCLOCK_COLOR
  HYPR_EFFECT
  WALLPAPER
)

# Defaults used when first-run has no state yet AND when older state files
# don't yet have the font-size fields (soft migration).
readonly DEFAULT_KITTY_FONT_SIZE=18
readonly DEFAULT_MAKO_FONT_SIZE=14
readonly DEFAULT_WOFI_FONT_SIZE=26
readonly DEFAULT_WAYBAR_FONT_SIZE=10
readonly DEFAULT_WAYBAR_DECOR=pointed
readonly DEFAULT_WAYBAR_VPN=off
readonly DEFAULT_WAYBAR_TRANSPARENT=on
readonly DEFAULT_WAYBAR_OPACITY=0.6
readonly DEFAULT_WAYBAR_LAUNCHER_LOGO=tux
readonly DEFAULT_HYPR_EFFECT=shadow

# Opacity picker ladder - 10% increments. `custom` drops to free-form input.
readonly OPACITY_LADDER=( 0.05 0.10 0.15 0.20 0.30 0.40 0.50 0.60 0.70 0.80 0.90 1.00 )

# Launcher logo axis - distro glyphs from the Nerd Fonts "Linux" range
# (plus Gentoo from devicons). The sed in apply_waybar rewrites the active
# `"format": "\uXXXX"` line inside the `custom/launcher` block on every
# apply, so cycling waybar variants preserves the chosen logo.
# Keyed values must match WAYBAR_LAUNCHER_LOGOS; fix a codepoint here if
# your Nerd Fonts version maps a distro to a different glyph.
readonly WAYBAR_LAUNCHER_LOGOS=(
  tux arch gentoo debian void nixos
  fedora fedora_inverse
  endeavouros cachyos opensuse artix
  slackware slackware_inverse
)
declare -A WAYBAR_LAUNCHER_GLYPHS=(
  [tux]=f17c
  [arch]=f303
  [gentoo]=e7e6
  [debian]=f306
  [void]=f32e
  [nixos]=f313
  [fedora]=f30a
  [fedora_inverse]=f30b
  [endeavouros]=f322
  [cachyos]=f303
  [opensuse]=f314
  [artix]=f31f
  [slackware]=f318
  [slackware_inverse]=f319
)
declare -A WAYBAR_LAUNCHER_NAMES=(
  [tux]='Tux'
  [arch]='Arch Linux'
  [gentoo]='Gentoo'
  [debian]='Debian'
  [void]='Void Linux'
  [nixos]='NixOS'
  [fedora]='Fedora'
  [fedora_inverse]='Fedora (inverse)'
  [endeavouros]='EndeavourOS'
  [cachyos]='CachyOS'
  [opensuse]='openSUSE'
  [artix]='Artix'
  [slackware]='Slackware'
  [slackware_inverse]='Slackware (inverse)'
)

# Wizard ladder for font-size pickers - custom... drops to free-form input.
# Denser at the low end (1-point steps 6-12) where differences matter most for
# dense fonts like Meslo; coarser at the top for hi-DPI / TV viewing distances.
readonly FONT_SIZE_LADDER=( 6 7 8 9 10 11 12 14 16 18 20 24 28 36 48 )

# Populated by load_state / cmd_set / wizard
for k in "${STATE_KEYS[@]}"; do declare -g "$k="; done

# ──────────────────────────────────────────────────────────────────────────────
#  Helpers
# ──────────────────────────────────────────────────────────────────────────────

die()   { printf 'dotctl: %s\n' "$*" >&2; exit 1; }
warn()  { printf 'dotctl: %s\n' "$*" >&2; }
info()  { printf '%s\n' "$*"; }
log()   { printf '[%s] %s\n' "$(date '+%F %T')" "$*" >> "$LOG_FILE" 2>/dev/null || true; }

contains() {
  local needle="$1"; shift
  local item
  for item in "$@"; do [[ "$item" == "$needle" ]] && return 0; done
  return 1
}

confirm() {
  local prompt="${1:-Continue?}" default="${2:-n}" reply
  local hint='[y/N]'
  [[ "$default" == "y" ]] && hint='[Y/n]'
  read -r -p "$prompt $hint " reply || true
  reply="${reply:-$default}"
  [[ "$reply" =~ ^[Yy] ]]
}

# ──────────────────────────────────────────────────────────────────────────────
#  State I/O
# ──────────────────────────────────────────────────────────────────────────────

state_exists() { [[ -f "$STATE_FILE" ]]; }

# One-time migration: older dotctl versions kept state at ~/.cache/dotctl/state.
# If the new config file is missing but the legacy one exists, move it in place.
migrate_legacy_state() {
  [[ -f "$STATE_FILE" ]] && return 0
  [[ -f "$LEGACY_STATE_FILE" ]] || return 0
  mkdir -p "$STATE_DIR"
  cp -f "$LEGACY_STATE_FILE" "$STATE_FILE"
  log "migrated legacy state $LEGACY_STATE_FILE -> $STATE_FILE"
  info "dotctl: migrated legacy state to $STATE_FILE"
}

load_state() {
  migrate_legacy_state
  state_exists || die "no state found. Run \`dotctl configure\` first."
  # shellcheck disable=SC1090
  source "$STATE_FILE"
  # Soft migration: font-size fields added after first release - if a state
  # file predates them, fall back to the hardcoded defaults so we don't die.
  : "${KITTY_FONT_SIZE:=$DEFAULT_KITTY_FONT_SIZE}"
  : "${MAKO_FONT_SIZE:=$DEFAULT_MAKO_FONT_SIZE}"
  : "${WOFI_FONT_SIZE:=$DEFAULT_WOFI_FONT_SIZE}"
  : "${WAYBAR_FONT_SIZE:=$DEFAULT_WAYBAR_FONT_SIZE}"
  : "${WAYBAR_DECOR:=$DEFAULT_WAYBAR_DECOR}"
  : "${WAYBAR_VPN:=$DEFAULT_WAYBAR_VPN}"
  : "${WAYBAR_TRANSPARENT:=$DEFAULT_WAYBAR_TRANSPARENT}"
  : "${WAYBAR_OPACITY:=$DEFAULT_WAYBAR_OPACITY}"
  : "${WAYBAR_LAUNCHER_LOGO:=$DEFAULT_WAYBAR_LAUNCHER_LOGO}"
  : "${HYPR_EFFECT:=$DEFAULT_HYPR_EFFECT}"
  # Style axis renames: zsh → console, bubble → pill. Auto-migrate old state.
  [[ "$WAYBAR_STYLE" == "zsh" ]]    && WAYBAR_STYLE="console"
  [[ "$WAYBAR_STYLE" == "bubble" ]] && WAYBAR_STYLE="pill"
  # tty-clock is opt-in at install time - allow TTYCLOCK_COLOR to stay empty
  # when the user didn't install tty-clock configs. apply_ttyclock/show/etc.
  # guard on ttyclock_available before touching this value.
  : "${TTYCLOCK_COLOR:=}"
  local k
  for k in "${STATE_KEYS[@]}"; do
    [[ "$k" == "TTYCLOCK_COLOR" ]] && continue
    [[ -n "${!k:-}" ]] || die "state file is missing key: $k. Run \`dotctl configure\` to repair."
  done
}

save_state() {
  mkdir -p "$STATE_DIR" "$CACHE_DIR"
  exec 8>"$STATE_LOCK"
  flock -w 2 8 || die "state lock busy"
  {
    printf '# dotctl config - hand-edit, then run `dotctl apply` (or let `dotctl watch` do it).\n'
    printf '# Regenerate with `dotctl configure`. Managed keys:\n'
    local k
    for k in "${STATE_KEYS[@]}"; do
      printf '%s=%q\n' "$k" "${!k}"
    done
  } > "$STATE_FILE"
  exec 8>&-
}

# ──────────────────────────────────────────────────────────────────────────────
#  Discovery - scan filesystem for available options
# ──────────────────────────────────────────────────────────────────────────────

_unique_sorted() { printf '%s\n' "$@" | awk 'NF' | sort -u; }

# Colors for cava = any top-level dir that contains a `config` file
detect_cava_colors() {
  local d
  for d in "$CAVA_DIR"/*/; do
    [[ -f "${d}config" ]] || continue
    basename "$d"
  done | sort -u
}

# tty-clock colors share the same shape as cava: top-level dirs with a
# `config` file (sourced by the tty-clock-themed wrapper, not tty-clock
# directly - tty-clock has no config format). Empty output when the user
# opted out of tty-clock at install time.
detect_ttyclock_colors() {
  [[ -d "$TTYCLOCK_DIR" ]] || return 0
  local d
  for d in "$TTYCLOCK_DIR"/*/; do
    [[ -f "${d}config" ]] || continue
    basename "$d"
  done | sort -u
}

# tty-clock integration is live iff at least one themed config dir exists.
# All tty-clock touch points in dotctl gate on this so users who opted out
# at install get a fully transparent degrade.
ttyclock_available() {
  [[ -d "$TTYCLOCK_DIR" ]] && [[ -n "$(detect_ttyclock_colors)" ]]
}

# Colors for kitty/mako = any <color>_<font> dir - we extract the leading color
# part (everything before the last _<font> suffix).
_detect_color_font_colors() {
  local base="$1" fonts=("${@:2}") d name color f
  for d in "$base"/*/; do
    [[ -d "$d" ]] || continue
    name=$(basename "$d")
    for f in "${fonts[@]}"; do
      if [[ "$name" == *_"$f" ]]; then
        color="${name%_$f}"
        printf '%s\n' "$color"
        break
      fi
    done
    :
  done | sort -u
}

detect_kitty_colors() { _detect_color_font_colors "$KITTY_DIR" meslo phoenix; }
detect_mako_colors()  { _detect_color_font_colors "$MAKO_DIR"  meslo phoenix; }
detect_wofi_colors()  { _detect_color_font_colors "$WOFI_DIR"  meslo phoenix; }

# Waybar colors come from palette files in ~/.config/waybar/palettes/<name>.palette.
detect_waybar_colors() {
  local f
  for f in "$WAYBAR_DIR"/palettes/*.palette; do
    [[ -f "$f" ]] || continue
    local name; name=$(basename "$f")
    printf '%s\n' "${name%.palette}"
  done | sort -u
}

# Font axis per element - scan dirs and collect suffixes.
_detect_fonts_for() {
  local base="$1" d name
  for d in "$base"/*/; do
    name=$(basename "$d")
    case "$name" in
      *_meslo)   printf 'meslo\n';;
      *_phoenix) printf 'phoenix\n';;
    esac
  done | sort -u
}

detect_kitty_fonts()  { _detect_fonts_for "$KITTY_DIR"; }
detect_mako_fonts()   { _detect_fonts_for "$MAKO_DIR"; }
detect_wofi_fonts()   { _detect_fonts_for "$WOFI_DIR"; }
detect_waybar_fonts() {
  local f
  for f in "$WAYBAR_DIR"/fonts/*.fontdef; do
    [[ -f "$f" ]] || continue
    local name; name=$(basename "$f")
    printf '%s\n' "${name%.fontdef}"
  done | sort -u
}

# Wofi variant subdirs inside each <color>_<font> dir - usually "1" and "2".
detect_wofi_variants() {
  local d sub
  declare -A seen=()
  for d in "$WOFI_DIR"/*/; do
    [[ -d "$d" ]] || continue
    for sub in "$d"*/; do
      [[ -d "$sub" ]] || continue
      name=$(basename "$sub")
      [[ "$name" =~ ^[0-9]+$ ]] || continue
      seen[$name]=1
    done
  done
  printf '%s\n' "${!seen[@]}" | sort -n
}

detect_waybar_styles()         { printf '%s\n' pill console; }
detect_waybar_scopes()         { printf '%s\n' full minimal; }
detect_waybar_vpns()           { printf '%s\n' off on; }
detect_waybar_transparents()   { printf '%s\n' on off; }
detect_waybar_opacities()      { printf '%s\n' "${OPACITY_LADDER[@]}"; }
detect_hypr_effects()          { printf '%s\n' shadow glow; }
detect_waybar_decors() {
  local f
  for f in "$WAYBAR_DIR"/decorators/*.glyphs; do
    [[ -f "$f" ]] || continue
    local name; name=$(basename "$f")
    printf '%s\n' "${name%.glyphs}"
  done | sort -u
}
detect_waybar_launcher_logos() { printf '%s\n' "${WAYBAR_LAUNCHER_LOGOS[@]}"; }

# Wallpaper themes = dirs in ~/Pictures/dotctl/wallpapers that have a matching cycle script in PATH.
detect_wallpapers() {
  local d name
  for d in "$WALLPAPER_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    name=$(basename "$d")
    if [[ -x "$(cycle_script "$name")" ]]; then
      printf '%s\n' "$name"
    fi
  done | sort -u
}

detect_wallpapers_orphan_dirs() {
  local d name
  for d in "$WALLPAPER_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    name=$(basename "$d")
    if [[ ! -x "$(cycle_script "$name")" ]]; then
      printf '%s\n' "$name"
    fi
  done | sort -u
}

detect_wallpapers_orphan_scripts() {
  local f name
  for f in "$CYCLE_DIR"/cycle-hyprpaper-*; do
    [[ -f "$f" ]] || continue
    name="${f##*/cycle-hyprpaper-}"
    [[ -d "$WALLPAPER_ROOT/$name" ]] || printf '%s\n' "$name"
  done
}

# Intersection of UI colors across every installed element - candidates for
# --color. tty-clock joins the intersection only when the user opted in at
# install time, so users without it don't see spurious "color missing from
# tty-clock" mismatches.
detect_ui_colors() {
  local required=5
  ttyclock_available && required=6
  {
    detect_cava_colors
    detect_kitty_colors
    detect_mako_colors
    detect_wofi_colors
    detect_waybar_colors
    ttyclock_available && detect_ttyclock_colors
  } | sort | uniq -c | awk -v n="$required" '$1==n {print $2}'
}

# ──────────────────────────────────────────────────────────────────────────────
#  Validation
# ──────────────────────────────────────────────────────────────────────────────

_in_list() {
  local needle="$1" item
  shift
  for item in "$@"; do [[ "$item" == "$needle" ]] && return 0; done
  return 1
}

validate_cava_color()    { _in_list "$1" $(detect_cava_colors); }
validate_kitty_color()   { _in_list "$1" $(detect_kitty_colors); }
validate_mako_color()    { _in_list "$1" $(detect_mako_colors); }
validate_wofi_color()    { _in_list "$1" $(detect_wofi_colors); }
validate_waybar_color()  { _in_list "$1" $(detect_waybar_colors); }
validate_ttyclock_color(){ _in_list "$1" $(detect_ttyclock_colors); }
validate_wallpaper()     { _in_list "$1" $(detect_wallpapers); }

validate_kitty_font()   { _in_list "$1" $(detect_kitty_fonts); }
validate_mako_font()    { _in_list "$1" $(detect_mako_fonts); }
validate_wofi_font()    { _in_list "$1" $(detect_wofi_fonts); }
validate_waybar_font()  { _in_list "$1" $(detect_waybar_fonts); }

validate_wofi_variant()         { _in_list "$1" $(detect_wofi_variants); }
validate_waybar_style()         { _in_list "$1" pill console; }
validate_waybar_scope()         { _in_list "$1" full minimal; }
validate_waybar_decor()         { _in_list "$1" $(detect_waybar_decors); }
validate_waybar_vpn()           { _in_list "$1" on off; }
# Is the VPN module actually usable? Both scripts must be resolvable.
waybar_vpn_available() {
  command -v vpnctl >/dev/null 2>&1 && command -v vpn-status-indicator >/dev/null 2>&1
}
validate_waybar_transparent()   { _in_list "$1" on off; }
validate_waybar_opacity() {
  local v="$1"
  [[ -n "$v" ]] || return 1
  [[ "$v" =~ ^[0-9]+(\.[0-9]+)?$ ]] || return 1
  awk -v n="$v" 'BEGIN { exit !(n >= 0 && n <= 1) }'
}
validate_hypr_effect()          { _in_list "$1" shadow glow; }
validate_waybar_launcher_logo() { _in_list "$1" "${WAYBAR_LAUNCHER_LOGOS[@]}"; }

# Accepts positive integer or decimal in [4, 72]. Empty value rejected.
validate_font_size() {
  local v="$1"
  [[ -n "$v" ]] || return 1
  [[ "$v" =~ ^[0-9]+(\.[0-9]+)?$ ]] || return 1
  awk -v n="$v" 'BEGIN { exit !(n >= 4 && n <= 72) }'
}

# Resolve paths for each element given its current state values
path_cava()     { printf '%s/%s/config\n' "$CAVA_DIR" "$1"; }
path_kitty()    { printf '%s/%s_%s/kitty.conf\n' "$KITTY_DIR" "$1" "$2"; }
path_mako()     { printf '%s/%s_%s/config\n' "$MAKO_DIR" "$1" "$2"; }
path_wofi()     { printf '%s/%s_%s/%s/style.css\n' "$WOFI_DIR" "$1" "$2" "$3"; }
path_waybar()   { printf '%s/%s_%s\n' "$WAYBAR_DIR" "$1" "$2"; }  # args: style, scope
path_ttyclock() { printf '%s/%s/config\n' "$TTYCLOCK_DIR" "$1"; }

# ──────────────────────────────────────────────────────────────────────────────
#  Apply functions - copy themed source into the live slot, reload the daemon
# ──────────────────────────────────────────────────────────────────────────────

apply_cava() {
  local src; src=$(path_cava "$CAVA_COLOR")
  [[ -f "$src" ]] || die "cava source missing: $src"
  cp -f "$src" "$CAVA_DIR/config"
  log "apply cava: $CAVA_COLOR"
  # cava doesn't hot-reload; user restarts it manually if running.
}

apply_ttyclock() {
  # Silent no-op when the user opted out of tty-clock at install time, or
  # has tty-clock installed but never configured a theme yet.
  ttyclock_available || return 0
  [[ -n "$TTYCLOCK_COLOR" ]] || return 0
  local src; src=$(path_ttyclock "$TTYCLOCK_COLOR")
  [[ -f "$src" ]] || die "tty-clock source missing: $src"
  cp -f "$src" "$TTYCLOCK_DIR/config"
  log "apply tty-clock: $TTYCLOCK_COLOR"
  # tty-clock has no IPC; users re-launch `tty-clock-themed` to pick up
  # the new palette.
}

apply_kitty() {
  local src; src=$(path_kitty "$KITTY_COLOR" "$KITTY_FONT")
  [[ -f "$src" ]] || die "kitty source missing: $src"
  cp -f "$src" "$KITTY_DIR/kitty.conf"
  # Replace `font_size        18.0` with the current state value. The sed
  # targets the active copy only - themed sources stay canonical.
  sed -i -E "s/^(font_size[[:space:]]+).*/\1${KITTY_FONT_SIZE}/" "$KITTY_DIR/kitty.conf"
  log "apply kitty: ${KITTY_COLOR}_${KITTY_FONT} size=${KITTY_FONT_SIZE}"
  # Existing kitty windows pick up changes on next launch - no reload.
}

apply_mako() {
  local src; src=$(path_mako "$MAKO_COLOR" "$MAKO_FONT")
  [[ -f "$src" ]] || die "mako source missing: $src"
  cp -f "$src" "$MAKO_DIR/config"
  # Replace trailing size in `font=<family> <size>` - family may contain spaces.
  sed -i -E "s/^(font=.* )[0-9]+(\.[0-9]+)?$/\1${MAKO_FONT_SIZE}/" "$MAKO_DIR/config"
  makoctl reload >/dev/null 2>&1 || warn "makoctl reload failed (mako running?)"
  log "apply mako: ${MAKO_COLOR}_${MAKO_FONT} size=${MAKO_FONT_SIZE}"
}

apply_wofi() {
  local src; src=$(path_wofi "$WOFI_COLOR" "$WOFI_FONT" "$WOFI_VARIANT")
  [[ -f "$src" ]] || die "wofi source missing: $src"
  cp -f "$src" "$WOFI_DIR/style.css"
  # Replace `font-size: 26px;` - preserves the px unit and surrounding text.
  sed -i -E "s/(font-size:[[:space:]]*)[0-9]+(\.[0-9]+)?px/\1${WOFI_FONT_SIZE}px/g" "$WOFI_DIR/style.css"
  log "apply wofi: ${WOFI_COLOR}_${WOFI_FONT}/$WOFI_VARIANT size=${WOFI_FONT_SIZE}"
  # wofi is launched on demand - next invocation picks up new CSS.
}

apply_waybar() {
  local src palette font decor
  src=$(path_waybar "$WAYBAR_STYLE" "$WAYBAR_SCOPE")
  palette="$WAYBAR_DIR/palettes/${WAYBAR_COLOR}.palette"
  font="$WAYBAR_DIR/fonts/${WAYBAR_FONT}.fontdef"
  decor="$WAYBAR_DIR/decorators/${WAYBAR_DECOR}.glyphs"

  [[ -d "$src" ]] || die "waybar source missing: $src"
  [[ -f "$src/config.jsonc" && -f "$src/style.css" ]] || die "waybar source incomplete: $src"
  [[ -f "$palette" ]] || die "waybar palette missing: $palette"
  [[ -f "$font" ]]    || die "waybar font missing: $font"
  [[ -f "$decor" ]]   || die "waybar decorator missing: $decor"

  cp -f "$src/config.jsonc" "$WAYBAR_DIR/config.jsonc"
  cp -f "$src/style.css"   "$WAYBAR_DIR/style.css"

  # Palette injection: replace the block between `/* PALETTE:BEGIN */` and
  # `/* PALETTE:END */` with the contents of the active palette file.
  awk -v palette_file="$palette" '
    /\/\* PALETTE:BEGIN/ {
      print
      while ((getline line < palette_file) > 0) print line
      close(palette_file)
      inside = 1
      next
    }
    /\/\* PALETTE:END/ { inside = 0 }
    !inside { print }
  ' "$WAYBAR_DIR/style.css" > "$WAYBAR_DIR/style.css.tmp" && mv -f "$WAYBAR_DIR/style.css.tmp" "$WAYBAR_DIR/style.css"

  # Font injection: same pattern, but inside the `#waybar { ... }` block, so
  # indent each injected line with 2 spaces.
  awk -v font_file="$font" '
    /\/\* FONT:BEGIN/ {
      print
      while ((getline line < font_file) > 0) print "  " line
      close(font_file)
      inside = 1
      next
    }
    /\/\* FONT:END/ { inside = 0 }
    !inside { print }
  ' "$WAYBAR_DIR/style.css" > "$WAYBAR_DIR/style.css.tmp" && mv -f "$WAYBAR_DIR/style.css.tmp" "$WAYBAR_DIR/style.css"

  # Override the bar font-size from state - scoped to `#waybar { ... }` so
  # larger chevron/separator font sizes elsewhere in the CSS stay authored.
  sed -i -E "/^#waybar[[:space:]]*\{/,/^\}/ s/(font-size:[[:space:]]*)[0-9]+(\.[0-9]+)?(pt|px)/\1${WAYBAR_FONT_SIZE}px/" "$WAYBAR_DIR/style.css"

  # Transparent bar background toggle: the canonical `#waybar { background:
  # transparent; }` block is wrapped in `/* TRANSPARENT:BEGIN */ ... END */`.
  # When WAYBAR_TRANSPARENT=off, replace the inner `background:` rule with an
  # opaque palette-aware fill. Marker comments are always stripped.
  awk -v want="$WAYBAR_TRANSPARENT" -v op="$WAYBAR_OPACITY" '
    /\/\* TRANSPARENT:BEGIN/ {
      if (want == "off") {
        printf "  background: alpha(@bg0, %s);\n", op
      } else {
        print "  background: transparent;"
      }
      skip = 1
      next
    }
    /\/\* TRANSPARENT:END/ { skip = 0; next }
    !skip { print }
  ' "$WAYBAR_DIR/style.css" > "$WAYBAR_DIR/style.css.tmp" && mv -f "$WAYBAR_DIR/style.css.tmp" "$WAYBAR_DIR/style.css"

  # VPN gate: the canonical files always contain VPN blocks wrapped in
  # `/* VPN:BEGIN */ ... /* VPN:END */`. At apply time we always strip the
  # marker comment lines themselves. When WAYBAR_VPN != on we additionally
  # drop everything between them.
  local _f _vpn_on=0
  [[ "$WAYBAR_VPN" == "on" ]] && _vpn_on=1
  for _f in "$WAYBAR_DIR/config.jsonc" "$WAYBAR_DIR/style.css"; do
    awk -v keep="$_vpn_on" '
      /\/\* VPN:BEGIN/ { if (keep != 1) skip = 1; next }
      /\/\* VPN:END/   { skip = 0; next }
      !skip { print }
    ' "$_f" > "$_f.tmp" && mv -f "$_f.tmp" "$_f"
  done

  # Decorator injection: for console style, swap the canonical pointed glyphs
  # with the active decorator's target glyphs in config.jsonc. The decorator
  # file holds one `FROM TO` pair per non-comment line.
  if [[ "$WAYBAR_STYLE" == "console" ]]; then
    local _from _to _rest
    while IFS= read -r _line || [[ -n "$_line" ]]; do
      _line="${_line%%#*}"
      [[ -z "${_line// }" ]] && continue
      read -r _from _to _rest <<<"$_line"
      [[ -n "$_from" && -n "$_to" ]] || continue
      sed -i "s/$_from/$_to/g" "$WAYBAR_DIR/config.jsonc"
    done < "$decor"
  fi

  # Rewrite the active launcher glyph inside the `custom/launcher` block.
  # Targets only the uncommented `"format": "\uXXXX"` line (leading quote,
  # no `//` prefix) so commented alternatives stay as reference.
  local glyph_hex pretty_name
  glyph_hex="${WAYBAR_LAUNCHER_GLYPHS[$WAYBAR_LAUNCHER_LOGO]:-f17c}"
  pretty_name="${WAYBAR_LAUNCHER_NAMES[$WAYBAR_LAUNCHER_LOGO]:-Tux}"
  sed -i -E '/"custom\/launcher":/,/^[[:space:]]*\},?[[:space:]]*$/ {
    /^[[:space:]]+"format":[[:space:]]*"\\u[0-9a-fA-F]{4}"/ s|^([[:space:]]+)"format":[[:space:]]*"\\u[0-9a-fA-F]{4}",.*|\1"format": "\\u'"$glyph_hex"'",  // '"$pretty_name"'|
  }' "$WAYBAR_DIR/config.jsonc"

  pkill -SIGUSR2 -x waybar 2>/dev/null || warn "waybar reload signal failed (waybar running?)"
  log "apply waybar: ${WAYBAR_STYLE}_${WAYBAR_SCOPE} color=${WAYBAR_COLOR} font=${WAYBAR_FONT}/${WAYBAR_FONT_SIZE} decor=${WAYBAR_DECOR} vpn=${WAYBAR_VPN} transparent=${WAYBAR_TRANSPARENT}/opacity=${WAYBAR_OPACITY} logo=${WAYBAR_LAUNCHER_LOGO}"
}

apply_wallpaper() {
  local script; script=$(cycle_script "$WALLPAPER")
  [[ -x "$script" ]] || die "wallpaper cycle script missing: $script"
  "$script" current
  log "apply wallpaper: $WALLPAPER (current image)"
}

# Resolve the hyprland color template - installed copy first, then the
# source tree copy next to this script (for uninstalled testing).
_hypr_template_path() {
  [[ -f "$HYPR_COLORS_TEMPLATE" ]] && { printf '%s\n' "$HYPR_COLORS_TEMPLATE"; return 0; }
  local self_dir
  self_dir=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
  if [[ -f "$self_dir/hypr/dotctl-colors.conf.tmpl" ]]; then
    printf '%s\n' "$self_dir/hypr/dotctl-colors.conf.tmpl"
    return 0
  fi
  return 1
}

# Parse a waybar `.palette` file into stdout as `NAME<space>HEX` lines,
# resolving `@other_name` aliases one pass deep. Chained aliases (rare in
# these palettes) are resolved in a second pass.
_parse_palette() {
  local file="$1"
  awk '
    /^@define-color[[:space:]]+/ {
      name = $2
      val  = $3
      sub(/;.*$/, "", val)
      print name, val
    }
  ' "$file"
}

apply_hypr() {
  local palette="$WAYBAR_DIR/palettes/${WAYBAR_COLOR}.palette"
  local template
  template=$(_hypr_template_path) || { warn "hypr colors template missing - skipping apply_hypr"; return 0; }
  [[ -f "$palette" ]] || { warn "hypr: palette missing: $palette"; return 0; }
  [[ -d "$HYPR_DIR" ]] || { log "hypr: $HYPR_DIR absent - skipping"; return 0; }

  # Build a name→hex map. Two-pass alias resolution handles `gold → @yellow`
  # style indirection; we bail out after 4 passes to avoid cycles.
  declare -A pal
  local name val
  while read -r name val; do
    [[ -z "$name" ]] && continue
    pal[$name]="$val"
  done < <(_parse_palette "$palette")

  local pass resolved=0
  for pass in 1 2 3 4; do
    resolved=1
    for name in "${!pal[@]}"; do
      val="${pal[$name]}"
      if [[ "$val" == @* ]]; then
        local ref="${val#@}"
        if [[ -n "${pal[$ref]:-}" ]]; then
          pal[$name]="${pal[$ref]}"
          [[ "${pal[$ref]}" == @* ]] && resolved=0
        fi
      fi
    done
    (( resolved == 1 )) && break
  done

  # Extract the slots we care about; strip leading `#` and lowercase.
  local cyan yellow bg3 black
  cyan=$(  printf '%s\n' "${pal[cyan]:-}"   | sed 's/^#//' | tr 'A-F' 'a-f')
  yellow=$(printf '%s\n' "${pal[yellow]:-}" | sed 's/^#//' | tr 'A-F' 'a-f')
  bg3=$(   printf '%s\n' "${pal[bg3]:-}"    | sed 's/^#//' | tr 'A-F' 'a-f')
  black=$( printf '%s\n' "${pal[black]:-}"  | sed 's/^#//' | tr 'A-F' 'a-f')
  # Fallbacks - any palette missing a slot gets a neutral grey so hyprland
  # doesn't choke on a literal placeholder.
  : "${cyan:=8888aa}"
  : "${yellow:=aaaa88}"
  : "${bg3:=333333}"
  : "${black:=111111}"

  # Shadow effect: `shadow` → dark drop shadow (@black, heavy alpha).
  #                `glow`   → colored glow matching the active border start (@cyan, softer alpha).
  local shadow_color shadow_alpha
  case "${HYPR_EFFECT:-shadow}" in
    glow)   shadow_color="$cyan";  shadow_alpha="88" ;;
    shadow|*) shadow_color="$black"; shadow_alpha="cc" ;;
  esac

  sed \
    -e "s/__CYAN__/${cyan}/g" \
    -e "s/__YELLOW__/${yellow}/g" \
    -e "s/__BG3__/${bg3}/g" \
    -e "s/__SHADOW_COLOR__/${shadow_color}/g" \
    -e "s/__SHADOW_ALPHA__/${shadow_alpha}/g" \
    "$template" > "$HYPR_COLORS_FILE.tmp" && mv -f "$HYPR_COLORS_FILE.tmp" "$HYPR_COLORS_FILE"

  # Reload hyprland in place if running. Silent on failure - the user may
  # not yet have sourced the file from their hyprland.conf.
  hyprctl reload >/dev/null 2>&1 || true
  log "apply hypr: colors from ${WAYBAR_COLOR}.palette → $HYPR_COLORS_FILE (effect=${HYPR_EFFECT:-shadow})"
}

apply_all() {
  apply_cava
  apply_kitty
  apply_mako
  apply_wofi
  apply_waybar
  apply_ttyclock
  apply_hypr
  apply_wallpaper
}

# Apply only the named elements (space-separated).
apply_subset() {
  local el
  for el in "$@"; do
    case "$el" in
      cava)      apply_cava;;
      kitty)     apply_kitty;;
      mako)      apply_mako;;
      wofi)      apply_wofi;;
      waybar)    apply_waybar;;
      tty-clock|ttyclock) apply_ttyclock;;
      hypr)      apply_hypr;;
      wallpaper) apply_wallpaper;;
      *) warn "unknown element: $el";;
    esac
  done
}

# ──────────────────────────────────────────────────────────────────────────────
#  `show` - pretty-print state + drift
# ──────────────────────────────────────────────────────────────────────────────

cmd_show() {
  case "${1:-}" in
    -h|--help|help)
      cat <<'EOF'
dotctl show

Pretty-print the current state, flag UI drift (colors or fonts diverging
across elements), indicate whether the active wallpaper has a matching UI
color theme, and warn about orphan wallpaper dirs or cycle scripts.

No arguments. Same output as `dotctl set` with no flags.
EOF
      return 0;;
  esac

  if ! state_exists; then
    info "dotctl: no state yet. Run \`dotctl configure\` to set up."
    return 0
  fi
  load_state

  info "dotctl state  ($STATE_FILE)"
  info ""
  printf '  %-10s color=%s\n' "cava"      "$CAVA_COLOR"
  printf '  %-10s color=%s  font=%s  size=%s\n' "kitty" "$KITTY_COLOR" "$KITTY_FONT" "$KITTY_FONT_SIZE"
  printf '  %-10s color=%s  font=%s  size=%s\n' "mako"  "$MAKO_COLOR" "$MAKO_FONT" "$MAKO_FONT_SIZE"
  printf '  %-10s color=%s  font=%s  size=%s  variant=%s\n' \
    "wofi" "$WOFI_COLOR" "$WOFI_FONT" "$WOFI_FONT_SIZE" "$WOFI_VARIANT"
  printf '  %-10s color=%s  font=%s  size=%s  style=%s  scope=%s  decor=%s  vpn=%s  transparent=%s  opacity=%s  logo=%s\n' \
    "waybar" "$WAYBAR_COLOR" "$WAYBAR_FONT" "$WAYBAR_FONT_SIZE" "$WAYBAR_STYLE" "$WAYBAR_SCOPE" "$WAYBAR_DECOR" "$WAYBAR_VPN" "$WAYBAR_TRANSPARENT" "$WAYBAR_OPACITY" "$WAYBAR_LAUNCHER_LOGO"
  if ttyclock_available; then
    printf '  %-10s color=%s\n' "tty-clock" "${TTYCLOCK_COLOR:-<unset>}"
  fi
  printf '  %-10s effect=%s\n' "hypr" "$HYPR_EFFECT"
  printf '  %-10s %s\n' "wallpaper" "$WALLPAPER"

  # Drift detection - tty-clock joins the color comparison only when the
  # user has it installed and configured (empty TTYCLOCK_COLOR would
  # falsely trigger drift).
  local ui_colors=( "$CAVA_COLOR" "$KITTY_COLOR" "$MAKO_COLOR" "$WOFI_COLOR" "$WAYBAR_COLOR" )
  if ttyclock_available && [[ -n "$TTYCLOCK_COLOR" ]]; then
    ui_colors+=( "$TTYCLOCK_COLOR" )
  fi
  local ui_fonts=( "$KITTY_FONT" "$MAKO_FONT" "$WOFI_FONT" "$WAYBAR_FONT" )
  local unique_colors unique_fonts
  unique_colors=$(printf '%s\n' "${ui_colors[@]}" | sort -u | wc -l)
  unique_fonts=$(printf '%s\n' "${ui_fonts[@]}" | sort -u | wc -l)

  info ""
  if (( unique_colors == 1 )) && (( unique_fonts == 1 )); then
    info "  drift:     none - UI is unified"
  else
    (( unique_colors > 1 )) && info "  drift:     UI colors differ across elements"
    (( unique_fonts  > 1 )) && info "  drift:     UI fonts differ across elements"
  fi

  # Wallpaper combo check
  if validate_waybar_color "$WALLPAPER" 2>/dev/null; then
    info "  wallpaper: $WALLPAPER - UI combo available"
  else
    info "  wallpaper: $WALLPAPER - wallpaper-only (no matching UI theme)"
  fi

  # Discovery warnings
  local orphan
  while IFS= read -r orphan; do
    [[ -z "$orphan" ]] && continue
    warn "wallpaper dir \`$orphan\` has no cycle-hyprpaper-$orphan script"
  done < <(detect_wallpapers_orphan_dirs)
  while IFS= read -r orphan; do
    [[ -z "$orphan" ]] && continue
    warn "cycle-hyprpaper-$orphan script has no matching ~/Pictures/dotctl/wallpapers/$orphan dir"
  done < <(detect_wallpapers_orphan_scripts)
}

# ──────────────────────────────────────────────────────────────────────────────
#  `list` - print valid values for an axis
# ──────────────────────────────────────────────────────────────────────────────

cmd_list() {
  local axis="${1:-}"
  case "$axis" in
    colors|ui-colors)   detect_ui_colors;;
    cava-colors)        detect_cava_colors;;
    kitty-colors)       detect_kitty_colors;;
    mako-colors)        detect_mako_colors;;
    wofi-colors)        detect_wofi_colors;;
    waybar-colors)      detect_waybar_colors;;
    tty-clock-colors|ttyclock-colors) detect_ttyclock_colors;;
    fonts)              detect_kitty_fonts;;
    kitty-fonts)        detect_kitty_fonts;;
    mako-fonts)         detect_mako_fonts;;
    wofi-fonts)         detect_wofi_fonts;;
    waybar-fonts)       detect_waybar_fonts;;
    styles)             detect_waybar_styles;;
    scopes)             detect_waybar_scopes;;
    waybar-decors|decors) detect_waybar_decors;;
    waybar-vpns|vpns) detect_waybar_vpns;;
    waybar-transparents|transparents) detect_waybar_transparents;;
    waybar-opacities|opacities) detect_waybar_opacities;;
    hypr-effects|effects) detect_hypr_effects;;
    launcher-logos|logos) detect_waybar_launcher_logos;;
    wofi-variants)      detect_wofi_variants;;
    waybar-variants)
      local s sc
      for s in pill console; do for sc in full minimal; do
        printf '%s_%s\n' "$s" "$sc"
      done; done
      ;;
    wallpapers)         detect_wallpapers;;
    presets)            [[ -d "$PRESET_DIR" ]] && ls -1 "$PRESET_DIR" 2>/dev/null | sed 's/\.conf$//';;
    ''|help)
      cat <<'EOF'
dotctl list <axis>

axes:
  colors           UI colors present across every installed UI element
  cava-colors      colors available for cava
  kitty-colors     colors available for kitty
  mako-colors      colors available for mako
  wofi-colors      colors available for wofi
  waybar-colors    colors available for waybar
  tty-clock-colors colors available for tty-clock (empty if opted out)
  fonts            fonts available (kitty)
  kitty-fonts
  mako-fonts
  wofi-fonts
  waybar-fonts
  styles           waybar style axis  (pill | console)
  scopes           waybar scope axis  (full | minimal)
  waybar-decors    waybar decorator glyph sets (pointed | round)
  waybar-vpns      waybar vpn module toggle (off | on)
  waybar-transparents  waybar transparent bar bg toggle (on | off)
  waybar-opacities     waybar bar opacity ladder [0.0-1.0]
  hypr-effects         hyprland window effect (shadow | glow)
  launcher-logos   waybar launcher distro glyphs
  wofi-variants    wofi subvariants (1 | 2)
  waybar-variants  canonical waybar style_scope combos
  wallpapers       wallpaper themes with a matching cycle script
  presets          saved presets under ~/.config/dotctl/presets
EOF
      ;;
    *) die "unknown axis: $axis - try \`dotctl list help\`";;
  esac
}

# ──────────────────────────────────────────────────────────────────────────────
#  `set` - flag parser and applier
# ──────────────────────────────────────────────────────────────────────────────

cmd_set() {
  if (( $# == 0 )); then
    cmd_show
    return 0
  fi

  # Handle --help before loading state so help works without a state file.
  local arg
  for arg in "$@"; do
    case "$arg" in -h|--help) _help_set; return 0;; esac
  done

  # State is required for all other set invocations.
  load_state

  # Shortcuts
  local new_color='' new_font='' new_font_size=''
  # Per-element
  local new_cava_color=''
  local new_kitty_color='' new_kitty_font='' new_kitty_font_size=''
  local new_mako_color='' new_mako_font='' new_mako_font_size=''
  local new_wofi_color='' new_wofi_font='' new_wofi_font_size='' new_wofi_variant=''
  local new_waybar_color='' new_waybar_font='' new_waybar_font_size='' new_waybar_style='' new_waybar_scope='' new_waybar_decor='' new_waybar_vpn='' new_waybar_transparent='' new_waybar_opacity='' new_waybar_launcher_logo='' new_hypr_effect=''
  local new_ttyclock_color=''
  local new_wallpaper=''
  local preset_name=''

  while (( $# > 0 )); do
    case "$1" in
      -c|--color)            new_color="$2"; shift 2;;
      -f|--font)             new_font="$2"; shift 2;;
      --font-size)           new_font_size="$2"; shift 2;;
      --cava-color)          new_cava_color="$2"; shift 2;;
      --kitty-color)         new_kitty_color="$2"; shift 2;;
      --kitty-font)          new_kitty_font="$2"; shift 2;;
      --kitty-font-size)     new_kitty_font_size="$2"; shift 2;;
      --mako-color)          new_mako_color="$2"; shift 2;;
      --mako-font)           new_mako_font="$2"; shift 2;;
      --mako-font-size)      new_mako_font_size="$2"; shift 2;;
      --wofi-color)          new_wofi_color="$2"; shift 2;;
      --wofi-font)           new_wofi_font="$2"; shift 2;;
      --wofi-font-size)      new_wofi_font_size="$2"; shift 2;;
      --wofi-variant)        new_wofi_variant="$2"; shift 2;;
      --waybar-color)        new_waybar_color="$2"; shift 2;;
      --waybar-font)         new_waybar_font="$2"; shift 2;;
      --waybar-font-size)    new_waybar_font_size="$2"; shift 2;;
      --waybar-style|-s)     new_waybar_style="$2"; shift 2;;
      --waybar-scope)        new_waybar_scope="$2"; shift 2;;
      --waybar-decor)        new_waybar_decor="$2"; shift 2;;
      --waybar-vpn)          new_waybar_vpn="$2"; shift 2;;
      --waybar-transparent)  new_waybar_transparent="$2"; shift 2;;
      --waybar-opacity)      new_waybar_opacity="$2"; shift 2;;
      --waybar-launcher-logo|--launcher-logo)
                             new_waybar_launcher_logo="$2"; shift 2;;
      --tty-clock-color|--ttyclock-color)
                             new_ttyclock_color="$2"; shift 2;;
      --hypr-effect)         new_hypr_effect="$2"; shift 2;;
      -w|--wallpaper)        new_wallpaper="$2"; shift 2;;
      --preset)              preset_name="$2"; shift 2;;
      -h|--help)             _help_set; return 0;;
      *) die "set: unknown flag \`$1\` - try \`dotctl set --help\`";;
    esac
  done

  # Precedence: preset < shortcut < per-element
  # 1. Apply preset
  if [[ -n "$preset_name" ]]; then
    _load_preset_into_state "$preset_name"
  fi

  # 2. Apply shortcuts (--color fans out to every installed UI element;
  #    --font to the 4 font-bearing elements). tty-clock only joins the
  #    fan-out when the user opted in at install time.
  if [[ -n "$new_color" ]]; then
    validate_cava_color   "$new_color" || die "--color: $new_color has no cava dir"
    validate_kitty_color  "$new_color" || die "--color: $new_color has no kitty dirs"
    validate_mako_color   "$new_color" || die "--color: $new_color has no mako dirs"
    validate_wofi_color   "$new_color" || die "--color: $new_color has no wofi dirs"
    validate_waybar_color "$new_color" || die "--color: $new_color has no waybar dirs"
    if ttyclock_available; then
      validate_ttyclock_color "$new_color" || die "--color: $new_color has no tty-clock dir"
    fi
    CAVA_COLOR="$new_color"
    KITTY_COLOR="$new_color"
    MAKO_COLOR="$new_color"
    WOFI_COLOR="$new_color"
    WAYBAR_COLOR="$new_color"
    ttyclock_available && TTYCLOCK_COLOR="$new_color"
  fi
  if [[ -n "$new_font" ]]; then
    validate_kitty_font  "$new_font" || die "--font: $new_font not available for kitty"
    validate_mako_font   "$new_font" || die "--font: $new_font not available for mako"
    validate_wofi_font   "$new_font" || die "--font: $new_font not available for wofi"
    validate_waybar_font "$new_font" || die "--font: $new_font not available for waybar"
    KITTY_FONT="$new_font"
    MAKO_FONT="$new_font"
    WOFI_FONT="$new_font"
    WAYBAR_FONT="$new_font"
  fi
  if [[ -n "$new_font_size" ]]; then
    validate_font_size "$new_font_size" || die "--font-size: $new_font_size must be a number in [4, 72]"
    KITTY_FONT_SIZE="$new_font_size"
    MAKO_FONT_SIZE="$new_font_size"
    WOFI_FONT_SIZE="$new_font_size"
    WAYBAR_FONT_SIZE="$new_font_size"
  fi

  # 3. Apply per-element overrides
  [[ -n "$new_cava_color" ]]        && { validate_cava_color   "$new_cava_color"   || die "invalid cava color: $new_cava_color";     CAVA_COLOR="$new_cava_color"; }
  [[ -n "$new_kitty_color" ]]       && { validate_kitty_color  "$new_kitty_color"  || die "invalid kitty color: $new_kitty_color";   KITTY_COLOR="$new_kitty_color"; }
  [[ -n "$new_kitty_font" ]]        && { validate_kitty_font   "$new_kitty_font"   || die "invalid kitty font: $new_kitty_font";     KITTY_FONT="$new_kitty_font"; }
  [[ -n "$new_kitty_font_size" ]]   && { validate_font_size    "$new_kitty_font_size"  || die "invalid kitty font size: $new_kitty_font_size";   KITTY_FONT_SIZE="$new_kitty_font_size"; }
  [[ -n "$new_mako_color" ]]        && { validate_mako_color   "$new_mako_color"   || die "invalid mako color: $new_mako_color";     MAKO_COLOR="$new_mako_color"; }
  [[ -n "$new_mako_font" ]]         && { validate_mako_font    "$new_mako_font"    || die "invalid mako font: $new_mako_font";       MAKO_FONT="$new_mako_font"; }
  [[ -n "$new_mako_font_size" ]]    && { validate_font_size    "$new_mako_font_size"   || die "invalid mako font size: $new_mako_font_size";    MAKO_FONT_SIZE="$new_mako_font_size"; }
  [[ -n "$new_wofi_color" ]]        && { validate_wofi_color   "$new_wofi_color"   || die "invalid wofi color: $new_wofi_color";     WOFI_COLOR="$new_wofi_color"; }
  [[ -n "$new_wofi_font" ]]         && { validate_wofi_font    "$new_wofi_font"    || die "invalid wofi font: $new_wofi_font";       WOFI_FONT="$new_wofi_font"; }
  [[ -n "$new_wofi_font_size" ]]    && { validate_font_size    "$new_wofi_font_size"   || die "invalid wofi font size: $new_wofi_font_size";    WOFI_FONT_SIZE="$new_wofi_font_size"; }
  [[ -n "$new_wofi_variant" ]]      && { validate_wofi_variant "$new_wofi_variant" || die "invalid wofi variant: $new_wofi_variant"; WOFI_VARIANT="$new_wofi_variant"; }
  [[ -n "$new_waybar_color" ]]      && { validate_waybar_color "$new_waybar_color" || die "invalid waybar color: $new_waybar_color"; WAYBAR_COLOR="$new_waybar_color"; }
  [[ -n "$new_waybar_font" ]]       && { validate_waybar_font  "$new_waybar_font"  || die "invalid waybar font: $new_waybar_font";   WAYBAR_FONT="$new_waybar_font"; }
  [[ -n "$new_waybar_font_size" ]]  && { validate_font_size    "$new_waybar_font_size" || die "invalid waybar font size: $new_waybar_font_size"; WAYBAR_FONT_SIZE="$new_waybar_font_size"; }
  [[ -n "$new_waybar_style" ]]      && { validate_waybar_style "$new_waybar_style" || die "invalid waybar style: $new_waybar_style"; WAYBAR_STYLE="$new_waybar_style"; }
  [[ -n "$new_waybar_scope" ]]      && { validate_waybar_scope "$new_waybar_scope" || die "invalid waybar scope: $new_waybar_scope"; WAYBAR_SCOPE="$new_waybar_scope"; }
  [[ -n "$new_waybar_decor" ]]      && { validate_waybar_decor "$new_waybar_decor" || die "invalid waybar decor: $new_waybar_decor (try \`dotctl list waybar-decors\`)"; WAYBAR_DECOR="$new_waybar_decor"; }
  if [[ -n "$new_waybar_vpn" ]]; then
    validate_waybar_vpn "$new_waybar_vpn" || die "invalid waybar vpn: $new_waybar_vpn (must be on|off)"
    if [[ "$new_waybar_vpn" == "on" ]] && ! waybar_vpn_available; then
      die "waybar vpn module not installed. Re-run install.sh with the VPN option, or install vpnctl + vpn-status-indicator manually."
    fi
    WAYBAR_VPN="$new_waybar_vpn"
  fi
  [[ -n "$new_waybar_transparent" ]]&& { validate_waybar_transparent "$new_waybar_transparent" || die "invalid waybar transparent: $new_waybar_transparent (must be on|off)"; WAYBAR_TRANSPARENT="$new_waybar_transparent"; }
  [[ -n "$new_waybar_opacity" ]]    && { validate_waybar_opacity "$new_waybar_opacity" || die "invalid waybar opacity: $new_waybar_opacity (must be a number in [0, 1])"; WAYBAR_OPACITY="$new_waybar_opacity"; }
  [[ -n "$new_waybar_launcher_logo" ]] && { validate_waybar_launcher_logo "$new_waybar_launcher_logo" || die "invalid waybar launcher logo: $new_waybar_launcher_logo (try \`dotctl list launcher-logos\`)"; WAYBAR_LAUNCHER_LOGO="$new_waybar_launcher_logo"; }
  if [[ -n "$new_ttyclock_color" ]]; then
    ttyclock_available || die "--tty-clock-color: tty-clock not installed. Re-run install.sh and accept the tty-clock prompt."
    validate_ttyclock_color "$new_ttyclock_color" || die "invalid tty-clock color: $new_ttyclock_color"
    TTYCLOCK_COLOR="$new_ttyclock_color"
  fi
  [[ -n "$new_hypr_effect" ]]       && { validate_hypr_effect "$new_hypr_effect" || die "invalid hypr effect: $new_hypr_effect (must be shadow|glow)"; HYPR_EFFECT="$new_hypr_effect"; }
  [[ -n "$new_wallpaper" ]]         && { validate_wallpaper    "$new_wallpaper"    || die "invalid wallpaper theme: $new_wallpaper"; WALLPAPER="$new_wallpaper"; }

  save_state
  apply_all
  info "dotctl: applied."
}

